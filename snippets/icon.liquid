{%- comment -%}
  Inline SVG icon — replaces lucide-via-JS so we don't ship 388 KB of icon data.
  Usage: {% render 'icon', name: 'shopping-bag' %}
         {% render 'icon', name: 'shopping-bag', size: 18 %}
         {% render 'icon', name: 'shopping-bag', class: 'my-custom-class' %}

  All icons are 24x24 viewBox, stroke-based, sized via CSS width/height by
  default. Pass `size` to set width+height inline, or `class` to attach extra
  classes (the base class is always `sn-icon` — style it once in CSS).
{%- endcomment -%}

{%- assign size = size | default: 18 -%}
{%- assign icon_class = 'sn-icon' -%}
{%- if class -%}{%- assign icon_class = icon_class | append: ' ' | append: class -%}{%- endif -%}

<svg xmlns="http://www.w3.org/2000/svg" width="{{ size }}" height="{{ size }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="{{ icon_class }}" aria-hidden="true">
{%- case name -%}
  {%- when 'alert-circle' -%}
    <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
  {%- when 'arrow-left' -%}
    <line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/>
  {%- when 'calendar' -%}
    <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
  {%- when 'check' -%}
    <polyline points="20 6 9 17 4 12"/>
  {%- when 'check-circle' -%}
    <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/>
  {%- when 'chevron-down' -%}
    <polyline points="6 9 12 15 18 9"/>
  {%- when 'chevron-left' -%}
    <polyline points="15 18 9 12 15 6"/>
  {%- when 'chevron-right' -%}
    <polyline points="9 18 15 12 9 6"/>
  {%- when 'copy' -%}
    <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
  {%- when 'droplet' -%}
    <path d="M12 2.69l5.66 5.66a8 8 0 1 1-11.31 0z"/>
  {%- when 'feather' -%}
    <path d="M20.24 12.24a6 6 0 0 0-8.49-8.49L5 10.5V19h8.5z"/><line x1="16" y1="8" x2="2" y2="22"/><line x1="17.5" y1="15" x2="9" y2="15"/>
  {%- when 'file-text' -%}
    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/>
