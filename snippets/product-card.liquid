{%- comment -%}
  Product Card snippet — matches the preview catalog card design.
  Usage: {% render 'product-card', product: product %}
{%- endcomment -%}

<div class="catalog-card" data-category="{{ product.type | handleize }}" data-product-id="{{ product.variants.first.id }}">
  {%- if product.metafields.custom.best_seller -%}
    <span class="catalog-card__badge">Best Seller</span>
  {%- endif -%}

  <img
    src="{{ product.featured_image | image_url: width: 400 }}"
    alt="{{ product.featured_image.alt | default: product.title | escape }}"
    width="400"
    height="200"
    loading="lazy"
    class="catalog-card__image"
  >

  <div class="catalog-card__body">
    {%- if product.type != blank -%}
      <span class="catalog-card__category">{{ product.type }}</span>
    {%- endif -%}
    <h3 class="catalog-card__title">{{ product.title }}</h3>
    {%- if product.metafields.custom.short_description != blank -%}
      <p class="catalog-card__desc">{{ product.metafields.custom.short_description }}</p>
    {%- elsif product.description != blank -%}
      <p class="catalog-card__desc">{{ product.description | strip_html | truncate: 80 }}</p>
    {%- endif -%}
    <div class="catalog-card__footer">
      <div>
        <span class="catalog-card__price" data-original-price="{{ product.price | money }}" data-sub-price="{{ product.price | times: 0.85 | round | money }}">
          {{ product.price | money }}
        </span>
      </div>
      <button
        class="btn btn--primary btn--sm"
        onclick="event.stopPropagation(); NutravaCart.addItem({id:{{ product.variants.first.id }},handle:'{{ product.handle }}',title:'{{ product.title | escape }}',price:{{ product.price }},quantity:1})"
      >
        Add to Cart
      </button>
    </div>
  </div>

  <!-- Expandable Details -->
  {%- if product.metafields.custom.about != blank -%}
    <div class="product-expand"><div class="product-expand__inner">
      <div class="product-expand__section">
        <span class="product-expand__label">About</span>
        <p class="product-expand__text">{{ product.metafields.custom.about }}</p>
      </div>
      {%- if product.metafields.custom.benefits != blank -%}
        <div class="product-expand__section">
          <span class="product-expand__label">Key Benefits</span>
          <ul class="product-expand__benefits">
            {%- for benefit in product.metafields.custom.benefits.value -%}
              <li>{{ benefit }}</li>
            {%- endfor -%}
          </ul>
        </div>
      {%- endif -%}
      <div class="product-expand__section">
        <span class="product-expand__label">Supplement Facts</span>
        <table class="product-expand__facts">
          <tr><td>Serving Size</td><td>{{ product.metafields.custom.serving_size | default: '2 capsules' }}</td></tr>
          {%- for ingredient in product.metafields.custom.ingredients.value -%}
            <tr><td>{{ ingredient.name }}</td><td>{{ ingredient.dose }}</td></tr>
          {%- endfor -%}
        </table>
      </div>
      {%- if product.metafields.custom.pairs_with != blank -%}
        <div class="product-expand__section">
          <span class="product-expand__label">Pairs Well With</span>
          <div class="product-expand__pairs">
            {%- for pair in product.metafields.custom.pairs_with.value -%}
              <span class="product-expand__pair">{{ pair }}</span>
            {%- endfor -%}
          </div>
        </div>
      {%- endif -%}
    </div></div>
    <button class="product-expand__toggle" onclick="event.stopPropagation(); toggleProductExpand(this)">View Details ↓</button>
  {%- endif -%}
</div>

<style>
  .catalog-card { background: #fff; border: 1.5px solid var(--color-border); border-radius: 16px; overflow: hidden; transition: all 0.25s; cursor: pointer; position: relative; display: flex; flex-direction: column; }
  .catalog-card:hover { border-color: var(--color-primary); transform: translateY(-4px); box-shadow: var(--shadow-hover); }
  .catalog-card__badge { position: absolute; top: 12px; left: 12px; background: var(--color-accent); color: #fff; font-size: 11px; font-weight: 700; padding: 4px 10px; border-radius: var(--radius-pill); letter-spacing: 0.5px; text-transform: uppercase; z-index: 2; }
  .catalog-card__image { width: 100%; height: 200px; object-fit: cover; display: block; }
  .catalog-card__body { padding: 20px; display: flex; flex-direction: column; flex: 1; }
  .catalog-card__category { font-size: 11px; font-weight: 600; letter-spacing: 1px; text-transform: uppercase; color: var(--color-primary); }
  .catalog-card__title { font-family: var(--font-heading); font-size: 1.1rem; color: var(--color-text); margin: 4px 0 8px; }
  .catalog-card__desc { font-size: 13px; color: var(--color-text-muted); line-height: 1.5; margin-bottom: 12px; }
  .catalog-card__footer { display: flex; justify-content: space-between; align-items: center; margin-top: auto; }
  .catalog-card__price { font-family: var(--font-heading); font-size: 1.1rem; color: var(--color-primary); display: block; }
</style>
