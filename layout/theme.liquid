<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">

  <title>
    {%- if page_title -%}
      {{ page_title }} — {{ shop.name }}
    {%- else -%}
      {{ shop.name }}
    {%- endif -%}
  </title>

  {%- liquid
    assign seo_desc = page_description
    unless seo_desc
      case template.name
        when 'index'
          assign seo_desc = 'Personalised supplement stacks backed by science. Take our free 60-second quiz to get a custom wellness plan tailored to your goals, lifestyle, and health.'
        when 'collection'
          assign seo_desc = collection.title | append: ' — science-backed supplements from Nutrava. Free UK shipping on orders over £50.'
        when 'product'
          assign seo_desc = product.title | append: ' — ' | append: product.description | strip_html | truncate: 140
        when 'page'
          if template.suffix == 'quiz'
            assign seo_desc = 'Take the free Nutrava quiz in 60 seconds. Get a personalised supplement stack based on your goals, sleep, energy, and lifestyle.'
          elsif template.suffix == 'about'
            assign seo_desc = 'Nutrava creates personalised, science-backed supplement stacks. Clean ingredients, no fillers, delivered to your door.'
          elsif template.suffix == 'contact'
            assign seo_desc = 'Get in touch with the Nutrava team. We are here to help with orders, quiz results, or any questions about your supplements.'
          elsif template.suffix == 'shipping'
            assign seo_desc = 'Free UK shipping on orders over £50. Learn about Nutrava delivery times, returns, and our 30-day money-back guarantee.'
          endif
        when 'cart'
          assign seo_desc = 'Your Nutrava cart — review your personalised supplement stack before checkout. Free UK shipping over £50.'
        when 'blog'
          assign seo_desc = 'Wellness insights and supplement science from Nutrava. Evidence-based articles on focus, sleep, energy, and performance.'
        when 'search'
          assign seo_desc = 'Search the Nutrava store for supplements, stacks, and wellness products personalised to your goals.'
      endcase
    endunless
  -%}
  {%- if seo_desc -%}
    <meta name="description" content="{{ seo_desc | escape }}">
  {%- endif -%}

  <link rel="canonical" href="{{ canonical_url }}">

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;1,400&family=Josefin+Sans:wght@300;400;500&display=swap" rel="stylesheet">
  {{ 'base.css' | asset_url | stylesheet_tag }}

  {%- comment -%} Inline critical above-fold styles to avoid render-blocking {%- endcomment -%}
  <style>
    .header{position:sticky;top:0;z-index:100;background:var(--color-bg);height:var(--header-height);display:flex;align-items:center;border-bottom:1px solid var(--color-border)}
    .header__logo{font-family:'Josefin Sans',sans-serif;font-size:1.4rem;font-weight:400;color:#2C1E14;text-decoration:none;letter-spacing:.27em;text-transform:uppercase}
    .hero{background:linear-gradient(180deg,var(--color-mint-mist) 0%,var(--color-bg) 100%);padding:48px 0}
    .hero__grid{display:grid;grid-template-columns:55% 45%;gap:48px;align-items:center}
    .hero__heading{margin-bottom:var(--space-md);line-height:1.2}
    .hero__image img{width:100%;height:auto;min-height:400px;object-fit:cover;display:block;border-radius:20px}
    @media(max-width:768px){.hero__grid{grid-template-columns:1fr;gap:32px}}
  </style>

  {% render 'social-meta' %}
  {% render 'json-ld-organization' %}

  {%- comment -%} Google Analytics 4 — set Measurement ID in Theme Settings → Analytics {%- endcomment -%}
  {%- if settings.ga4_measurement_id != blank -%}
    <script async src="https://www.googletagmanager.com/gtag/js?id={{ settings.ga4_measurement_id }}"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', '{{ settings.ga4_measurement_id }}');
    </script>
  {%- endif -%}

  {%- comment -%} Meta Pixel — set Pixel ID in Theme Settings → Analytics {%- endcomment -%}
  {%- if settings.meta_pixel_id != blank -%}
    <script>
      !function(f,b,e,v,n,t,s){if(f.fbq)return;n=f.fbq=function(){n.callMethod?
      n.callMethod.apply(n,arguments):n.queue.push(arguments)};if(!f._fbq)f._fbq=n;
      n.push=n;n.loaded=!0;n.version='2.0';n.queue=[];t=b.createElement(e);t.async=!0;
      t.src=v;s=b.getElementsByTagName(e)[0];s.parentNode.insertBefore(t,s)}(window,
      document,'script','https://connect.facebook.net/en_US/fbevents.js');
      fbq('init', '{{ settings.meta_pixel_id }}');
      fbq('track', 'PageView');
    </script>
  {%- endif -%}

  {%- comment -%} Klaviyo — set Public API Key in Theme Settings → Analytics {%- endcomment -%}
  {%- if settings.klaviyo_public_key != blank -%}
    <script async src="https://static.klaviyo.com/onsite/js/klaviyo.js?company_id={{ settings.klaviyo_public_key }}"></script>
  {%- endif -%}

  {{ content_for_header }}
</head>
<body class="template-{{ template.name | handle }}">
  <a class="skip-to-content" href="#main">{{ 'general.skip_to_content' | t }}</a>

  {% section 'announcement-bar' %}
  {% section 'header' %}

  <main id="main" role="main">
    {{ content_for_layout }}
  </main>

  {% section 'footer' %}
  {% section 'cart-drawer' %}
  {% render 'search-modal' %}

  <script src="{{ 'theme.js' | asset_url }}" defer></script>
  <script src="{{ 'lucide.min.js' | asset_url }}" defer onload="lucide.createIcons()"></script>
  <script src="{{ 'cart.js' | asset_url }}" defer></script>
</body>
</html>
