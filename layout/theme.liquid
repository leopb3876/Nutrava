<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">

  <title>
    {%- if page_title -%}
      {{ page_title }} — {{ shop.name }}
    {%- else -%}
      {{ shop.name }}
    {%- endif -%}
  </title>

  {%- liquid
    assign seo_desc = page_description
    unless seo_desc
      case template.name
        when 'index'
          assign seo_desc = 'Personalised skincare routines matched to your skin. Take our free 60-second quiz and get a routine built for your skin type, concerns and habits.'
        when 'collection'
          assign seo_desc = collection.title | append: ' — clean, clinically-dosed skincare from Nutrava. Free US shipping on orders over $50.'
        when 'product'
          assign seo_desc = product.title | append: ' — ' | append: product.description | strip_html | truncate: 140
        when 'page'
          if template.suffix == 'quiz'
            assign seo_desc = 'Take the free Nutrava skincare quiz — under 60 seconds. Get a personalised routine based on your skin type, top concern, and current habits.'
          elsif template.suffix == 'about'
            assign seo_desc = 'Nutrava builds personalised skincare routines matched to your skin. Clean, cruelty-free formulas with transparent ingredient lists.'
          elsif template.suffix == 'contact'
            assign seo_desc = 'Get in touch with the Nutrava team. We are here to help with orders, quiz results, or any questions about your routine.'
          elsif template.suffix == 'shipping'
            assign seo_desc = 'Free US shipping on orders over $50. Learn about Nutrava delivery times, returns, and our 30-day money-back guarantee.'
          endif
        when 'cart'
          assign seo_desc = 'Your Nutrava cart — review your personalised skincare routine before checkout. Free US shipping over $50.'
        when 'blog'
          assign seo_desc = 'Skincare insights and ingredient science from Nutrava. Evidence-based articles on actives, routines, and skin health.'
        when 'search'
          assign seo_desc = 'Search the Nutrava store for skincare products and routines matched to your skin.'
      endcase
    endunless
  -%}
  {%- if seo_desc -%}
    <meta name="description" content="{{ seo_desc | escape }}">
  {%- endif -%}

  <link rel="canonical" href="{{ canonical_url }}">

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght,SOFT,WONK@0,9..144,400..700,0..100,0..1;1,9..144,400..700,0..100,0..1&family=Inter+Tight:wght@400;500;600;700&display=swap" rel="stylesheet">
  {{ 'base.css' | asset_url | stylesheet_tag }}
  {{ 'selfnamed.css' | asset_url | stylesheet_tag }}

  {%- comment -%} Inline critical above-fold styles to avoid render-blocking {%- endcomment -%}
  <style>
    body.template-index,body.template-page{font-family:"Inter Tight",-apple-system,system-ui,sans-serif;color:#0F1010;background:#fff;letter-spacing:-0.005em}
    .sn-topbar{background:#FBF4E6;color:#0F1010;text-align:center;font-size:13px;letter-spacing:-0.01em;padding:10px 16px;border-bottom:1px solid rgba(15,16,16,0.08)}
    .sn-nav{display:flex;align-items:center;justify-content:space-between;padding:18px 32px;max-width:1240px;margin:0 auto;gap:24px}
    .sn-hero{text-align:center;padding:80px 32px 100px}
    .sn-hero__title{font-family:"Fraunces",serif;font-weight:500;font-size:clamp(48px,7vw,96px);line-height:1.0;letter-spacing:-0.04em;margin:0 auto 28px}
    @media(max-width:640px){.sn-hero{padding:48px 20px 64px}}
  </style>

  {% render 'social-meta' %}
  {% render 'json-ld-organization' %}

  {%- comment -%} Google Analytics 4 — set Measurement ID in Theme Settings → Analytics {%- endcomment -%}
  {%- if settings.ga4_measurement_id != blank -%}
    <script async src="https://www.googletagmanager.com/gtag/js?id={{ settings.ga4_measurement_id }}"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', '{{ settings.ga4_measurement_id }}');
    </script>
  {%- endif -%}

  {%- comment -%} Meta Pixel — set Pixel ID in Theme Settings → Analytics {%- endcomment -%}
  {%- if settings.meta_pixel_id != blank -%}
    <script>
      !function(f,b,e,v,n,t,s){if(f.fbq)return;n=f.fbq=function(){n.callMethod?
      n.callMethod.apply(n,arguments):n.queue.push(arguments)};if(!f._fbq)f._fbq=n;
      n.push=n;n.loaded=!0;n.version='2.0';n.queue=[];t=b.createElement(e);t.async=!0;
      t.src=v;s=b.getElementsByTagName(e)[0];s.parentNode.insertBefore(t,s)}(window,
      document,'script','https://connect.facebook.net/en_US/fbevents.js');
      fbq('init', '{{ settings.meta_pixel_id }}');
      fbq('track', 'PageView');
    </script>
  {%- endif -%}

  {%- comment -%} Klaviyo — set Public API Key in Theme Settings → Analytics {%- endcomment -%}
  {%- if settings.klaviyo_public_key != blank -%}
    <script async src="https://static.klaviyo.com/onsite/js/klaviyo.js?company_id={{ settings.klaviyo_public_key }}"></script>
  {%- endif -%}

  {{ content_for_header }}
</head>
<body class="template-{{ template.name | handle }}">
  <a class="skip-to-content" href="#main">{{ 'general.skip_to_content' | t }}</a>

  {% section 'announcement-bar' %}
  {% section 'header' %}

  <main id="main" role="main">
    {{ content_for_layout }}
  </main>

  {% section 'footer' %}
  {% section 'cart-drawer' %}
  {% render 'search-modal' %}

  <script src="{{ 'theme.js' | asset_url }}" defer></script>
  <script src="{{ 'lucide.min.js' | asset_url }}" defer onload="lucide.createIcons()"></script>
  <script src="{{ 'cart.js' | asset_url }}" defer></script>
  {% render 'cookie-consent' %}
</body>
</html>
