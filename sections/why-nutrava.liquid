<section class="why-nutrava section-padding" style="background: var(--color-mint-mist);" data-fade-in>
  <div class="container">
    <div class="section-head text-center mb-xl">
      <h2>{{ section.settings.heading | default: 'The Nutrava Difference' }}</h2>
      <p class="text-muted mt-sm">{{ section.settings.subheading | default: 'What sets us apart from generic skincare brands' }}</p>
    </div>
    <div class="why-nutrava__grid">
      {%- for block in section.blocks -%}
        <div class="why-card" {{ block.shopify_attributes }}>
          <div class="why-card__icon">
            <i data-lucide="{{ block.settings.icon }}"></i>
          </div>
          <div class="why-card__stat">{{ block.settings.stat }}</div>
          <h3 class="why-card__title">{{ block.settings.title }}</h3>
          <p class="why-card__text">{{ block.settings.text }}</p>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
  .why-nutrava__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    max-width: 900px;
    margin: 0 auto;
  }

  .why-card {
    background: var(--color-card-bg);
    border-radius: var(--radius-lg);
    padding: var(--space-xl);
    text-align: center;
    border: 1px solid var(--color-border);
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .why-card:hover {
    border-color: var(--color-primary);
    box-shadow: 0 4px 20px rgba(90,122,94,0.08);
  }

  .why-card__icon {
    width: 48px;
    height: 48px;
    background: var(--color-mint-mist);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto var(--space-md);
    color: var(--color-primary);
  }

  .why-card__icon svg {
    width: 24px;
    height: 24px;
    stroke-width: 1.75;
  }

  .why-card__stat {
    font-family: var(--font-heading);
    font-size: clamp(1.5rem, 3vw, 2.2rem);
    color: var(--color-text);
    line-height: 1.1;
    margin-bottom: 4px;
  }

  .why-card__title {
    font-family: var(--font-heading);
    font-size: 1rem;
    color: var(--color-text);
    margin-bottom: var(--space-sm);
    font-weight: 700;
  }

  .why-card__text {
    font-size: 14px;
    color: var(--color-text-body);
    line-height: 1.6;
    margin: 0;
  }

  @media (max-width: 480px) {
    .why-nutrava__grid {
      grid-template-columns: 1fr;
    }
  }
</style>

{% schema %}
{
  "name": "Why Nutrava",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The Nutrava Difference"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "What sets us apart from generic skincare brands"
    }
  ],
  "blocks": [
    {
      "type": "point",
      "name": "Differentiator",
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "Lucide icon name",
          "default": "user"
        },
        {
          "type": "text",
          "id": "stat",
          "label": "Stat / number",
          "default": "Unique"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Personalised to You"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Description",
          "default": "No one-size-fits-all. Your routine is matched to your skin type, concerns, sensitivity, and current habits."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Why Nutrava",
      "blocks": [
        { "type": "point", "settings": { "icon": "user", "stat": "Unique", "title": "Personalised to You", "text": "No one-size-fits-all. Your routine is matched to your skin type, concerns, sensitivity, and current habits." } },
        { "type": "point", "settings": { "icon": "flask-conical", "stat": "100%", "title": "Clinically Dosed", "text": "Every ingredient at its researched effective dose. No pixie dusting, no under-dosing, no shortcuts." } },
        { "type": "point", "settings": { "icon": "shield-check", "stat": "Zero", "title": "Fragrance, Fillers, Drama", "text": "No synthetic fragrance, no harsh sulphates, no proprietary blends. Clean formulas your skin can trust." } },
        { "type": "point", "settings": { "icon": "eye", "stat": "100%", "title": "Transparent Labels", "text": "You see exactly what's inside and how much. Third-party lab tested for purity and potency." } }
      ]
    }
  ]
}
{% endschema %}
