<section class="hero" data-fade-in>
  <div class="container">
    <div class="hero__content">
      <span class="label">{{ section.settings.label }}</span>
      <h1 class="hero__heading">{{ section.settings.heading }}</h1>
      <p class="hero__subheading">{{ section.settings.subheading }}</p>
      <div class="hero__actions">
        <a href="/pages/quiz" class="btn btn--primary btn--lg">{{ section.settings.cta_quiz }}</a>
        <a href="/collections/all" class="btn btn--outline btn--lg">{{ section.settings.cta_shop }}</a>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    background: linear-gradient(135deg, var(--color-mint-mist) 0%, var(--color-sand) 100%);
    padding: var(--space-4xl) 0;
    text-align: center;
  }

  .hero__content {
    max-width: 600px;
    margin: 0 auto;
  }

  .hero .label {
    display: block;
    margin-bottom: var(--space-md);
  }

  .hero__heading {
    margin-bottom: var(--space-md);
    line-height: 1.2;
  }

  .hero__subheading {
    font-size: 1.125rem;
    color: var(--color-text-body);
    margin-bottom: var(--space-xl);
    line-height: 1.6;
  }

  .hero__actions {
    display: flex;
    gap: var(--space-md);
    justify-content: center;
    flex-wrap: wrap;
  }

  @media (max-width: 768px) {
    .hero {
      padding: var(--space-3xl) 0;
    }

    .hero__actions {
      flex-direction: column;
      align-items: center;
    }

    .hero__actions .btn {
      width: 100%;
      max-width: 300px;
    }
  }
</style>

{% schema %}
{
  "name": "Hero",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Label",
      "default": "Personalised Wellness"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Your Wellness, Personalised"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Take our 60-second quiz and discover your science-backed supplement stack"
    },
    {
      "type": "text",
      "id": "cta_quiz",
      "label": "Quiz button text",
      "default": "Take the Quiz"
    },
    {
      "type": "text",
      "id": "cta_shop",
      "label": "Shop button text",
      "default": "Shop Stacks"
    }
  ],
  "presets": [
    {
      "name": "Hero"
    }
  ]
}
{% endschema %}
