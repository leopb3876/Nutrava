<section class="sn-hero">
  <div class="sn-hero__grid">

    <div class="sn-hero__content">
      {%- if section.settings.eyebrow != blank -%}
        <span class="sn-hero__eyebrow"><span class="sn-hero__dot"></span> {{ section.settings.eyebrow }}</span>
      {%- endif -%}

      <h1 class="sn-hero__title">
        {{ section.settings.heading_before }}<br>
        <em data-rotate-word>{{ section.settings.heading_word }}</em>
      </h1>

      <p class="sn-hero__sub">{{ section.settings.subheading }}</p>

      {%- if section.blocks.size > 0 -%}
        <div class="sn-hero__check-row">
          {%- for block in section.blocks -%}
            {%- if block.type == 'check' -%}
              <span class="sn-hero__check" {{ block.shopify_attributes }}>{{ block.settings.text }}</span>
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- endif -%}

      {%- if section.settings.rating_text != blank -%}
        <div class="sn-hero__rating">
          <span class="sn-hero__rating-mark">H</span>
          <span class="sn-hero__rating-stars">★★★★★</span>
          <span class="sn-hero__rating-text">{{ section.settings.rating_text }}</span>
        </div>
      {%- endif -%}

      <div class="sn-hero__cta">
        <a href="/pages/quiz" class="sn-btn sn-btn--ink">{{ section.settings.cta_quiz }}</a>
        <a href="/collections/all" class="sn-btn sn-btn--ghost">{{ section.settings.cta_shop }}</a>
      </div>
    </div>

    <div class="sn-hero__visual">
      {%- if section.settings.image != blank -%}
        <img
          class="sn-hero__image"
          srcset="{{ section.settings.image | image_url: width: 600 }} 600w,
                  {{ section.settings.image | image_url: width: 900 }} 900w,
                  {{ section.settings.image | image_url: width: 1200 }} 1200w"
          sizes="(max-width: 980px) 100vw, 45vw"
          src="{{ section.settings.image | image_url: width: 900 }}"
          alt="{{ section.settings.image.alt | default: section.settings.heading_before | escape }}"
          loading="eager"
          fetchpriority="high"
          width="900"
          height="1100"
        >
      {%- else -%}
        <div class="sn-hero__placeholder" aria-hidden="true">
          <div class="sn-hero__placeholder-bottle"></div>
          <div class="sn-hero__placeholder-blob sn-hero__placeholder-blob--tr"></div>
          <div class="sn-hero__placeholder-blob sn-hero__placeholder-blob--bl"></div>
        </div>
      {%- endif -%}
    </div>

  </div>
</section>

<style>
  .sn-hero {
    padding: 64px 32px 96px;
    max-width: var(--sn-w-page);
    margin: 0 auto;
  }
  .sn-hero__grid {
    display: grid;
    grid-template-columns: 1.05fr 1fr;
    gap: 64px;
    align-items: center;
  }
  .sn-hero__content {
    text-align: left;
    max-width: 600px;
  }
  .sn-hero__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--sn-cream);
    border-radius: var(--sn-r-pill);
    padding: 8px 18px;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--sn-ink-soft);
    margin-bottom: 24px;
  }
  .sn-hero__dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--sn-amber);
  }
  .sn-hero__title {
    font-family: var(--sn-display);
    font-weight: 500;
    font-size: clamp(44px, 5.6vw, 86px);
    line-height: 1.0;
    letter-spacing: -0.04em;
    margin: 0 0 24px;
    font-variation-settings: "SOFT" 50, "WONK" 0, "opsz" 144;
  }
  .sn-hero__title em {
    font-style: italic;
    font-weight: 400;
    color: var(--sn-amber);
    font-variation-settings: "SOFT" 100, "WONK" 1, "opsz" 144;
    display: inline-block;
    transform-origin: 50% 70%;
    will-change: transform, opacity;
    animation: sn-word-reveal 1.4s cubic-bezier(0.16, 1, 0.3, 1) 0.2s both;
  }
  @keyframes sn-word-reveal {
    from { opacity: 0; transform: translate3d(0, 0.28em, 0) scale(0.97); }
    to   { opacity: 1; transform: translate3d(0, 0, 0) scale(1); }
  }
  @media (prefers-reduced-motion: reduce) {
    .sn-hero__title em { animation: none; }
  }
  .sn-hero__sub {
    font-size: 18px;
    color: var(--sn-ink-soft);
    max-width: 520px;
    margin: 0 0 28px;
    letter-spacing: -0.01em;
    line-height: 1.55;
  }
  .sn-hero__check-row {
    display: flex; flex-wrap: wrap;
    gap: 14px 28px;
    margin: 0 0 28px;
  }
  .sn-hero__check {
    display: inline-flex; align-items: center; gap: 8px;
    font-size: 14px;
    font-weight: 500;
    color: var(--sn-ink-soft);
  }
  .sn-hero__check::before {
    content: "";
    width: 18px; height: 18px;
    border-radius: 50%;
    background: var(--sn-sage);
    display: inline-block;
    flex: none;
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='%233F5238' stroke-width='3' stroke-linecap='round' stroke-linejoin='round'><polyline points='20 6 9 17 4 12'/></svg>");
    background-size: 12px;
    background-repeat: no-repeat;
    background-position: center;
  }
  .sn-hero__rating {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    background: var(--sn-cream);
    border-radius: var(--sn-r-pill);
    padding: 10px 22px 10px 14px;
    margin-bottom: 28px;
  }
  .sn-hero__rating-mark {
    width: 28px; height: 28px;
    border-radius: 50%;
    background: var(--sn-ink);
    color: var(--sn-paper);
    display: grid; place-items: center;
    font-size: 14px; font-weight: 700;
  }
  .sn-hero__rating-stars { color: var(--sn-amber); letter-spacing: 1px; font-size: 13px; }
  .sn-hero__rating-text { font-size: 13px; color: var(--sn-ink-soft); font-weight: 500; }
  .sn-hero__cta {
    display: flex; gap: 12px; flex-wrap: wrap;
  }

  /* ---------- Visual / image side ---------- */
  .sn-hero__visual {
    position: relative;
    aspect-ratio: 4 / 5;
    border-radius: var(--sn-r-card-lg);
    overflow: hidden;
    background: var(--sn-cream);
  }
  .sn-hero__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* ---------- Fallback placeholder when no image is set ---------- */
  .sn-hero__placeholder {
    position: relative;
    width: 100%;
    height: 100%;
    background: linear-gradient(160deg, var(--sn-cream) 0%, var(--sn-peach) 100%);
    overflow: hidden;
  }
  .sn-hero__placeholder-bottle {
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    width: 30%;
    aspect-ratio: 0.55;
    background: linear-gradient(180deg, rgba(255,255,255,0.95) 0%, rgba(255,255,255,0.6) 100%);
    border-radius: 28px 28px 14px 14px;
    border: 1px solid rgba(15,16,16,0.08);
    box-shadow: 0 24px 60px -20px rgba(15,16,16,0.18);
    z-index: 2;
  }
  .sn-hero__placeholder-bottle::before {
    content: "";
    position: absolute;
    top: -28px; left: 50%;
    transform: translateX(-50%);
    width: 38%; height: 32px;
    background: var(--sn-ink);
    border-radius: 6px 6px 3px 3px;
  }
  .sn-hero__placeholder-bottle::after {
    content: "Hisae";
    position: absolute;
    top: 36%; left: 12%; right: 12%;
    background: var(--sn-paper);
    padding: 12px 6px;
    font-family: "Bodoni Moda", "Times New Roman", serif;
    font-size: 14px;
    font-weight: 500;
    text-align: center;
    letter-spacing: -0.01em;
    color: var(--sn-ink);
    border-top: 1px solid rgba(15,16,16,0.05);
    border-bottom: 1px solid rgba(15,16,16,0.05);
  }
  .sn-hero__placeholder-blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(40px);
    pointer-events: none;
  }
  .sn-hero__placeholder-blob--tr {
    top: -80px; right: -80px;
    width: 320px; height: 320px;
    background: radial-gradient(circle, rgba(255,255,255,0.7) 0%, transparent 60%);
    z-index: 1;
  }
  .sn-hero__placeholder-blob--bl {
    bottom: -80px; left: -80px;
    width: 280px; height: 280px;
    background: radial-gradient(circle, var(--sn-lilac) 0%, transparent 60%);
    opacity: 0.6;
    z-index: 1;
  }

  /* ---------- Responsive: stack to single column + recenter ---------- */
  @media (max-width: 980px) {
    .sn-hero__grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }
    .sn-hero__content {
      text-align: center;
      max-width: 600px;
      margin: 0 auto;
    }
    .sn-hero__sub { margin-left: auto; margin-right: auto; }
    .sn-hero__check-row { justify-content: center; }
    .sn-hero__cta { justify-content: center; }
    .sn-hero__visual {
      max-width: 480px;
      margin: 0 auto;
      aspect-ratio: 1 / 1;
    }
  }
  @media (max-width: 640px) {
    .sn-hero { padding: 40px 20px 56px; }
    .sn-hero__sub { font-size: 16px; }
  }
</style>

<script>
  (function () {
    var el = document.querySelector('[data-rotate-word]');
    if (!el || !el.dataset.words) {
      var defaultWords = ['understood','decoded','listened to','balanced','nurtured','mapped','considered','read','known','studied','cared for','matched','restored','revealed','protected'];
      var words = defaultWords;
    } else {
      var words = el.dataset.words.split('|').map(function (w) { return w.trim(); }).filter(Boolean);
    }
    if (!el || words.length === 0) return;
    var pick = words[Math.floor(Math.random() * words.length)];
    el.textContent = pick;
  })();
</script>

{% schema %}
{
  "name": "Hero",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "Personalised clean skincare"
    },
    {
      "type": "text",
      "id": "heading_before",
      "label": "Heading (first line)",
      "default": "Your skin,"
    },
    {
      "type": "text",
      "id": "heading_word",
      "label": "Italic accent word (rotates if multiple words below)",
      "default": "understood"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Take our 60-second quiz and we'll match you with a clean skincare routine engineered around your skin type, concerns, and current habits."
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero image (right side) — leave empty to use placeholder bottle"
    },
    {
      "type": "text",
      "id": "rating_text",
      "label": "Rating text",
      "default": "4.9 · 50+ verified routines built"
    },
    {
      "type": "text",
      "id": "cta_quiz",
      "label": "Primary button text",
      "default": "Take the Free Quiz"
    },
    {
      "type": "text",
      "id": "cta_shop",
      "label": "Secondary button text",
      "default": "Browse Products"
    }
  ],
  "blocks": [
    {
      "type": "check",
      "name": "Check item",
      "settings": [
        { "type": "text", "id": "text", "label": "Text", "default": "5 skin concerns" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero",
      "blocks": [
        { "type": "check", "settings": { "text": "5 skin concerns" } },
        { "type": "check", "settings": { "text": "20 clean formulas" } },
        { "type": "check", "settings": { "text": "30-day money-back guarantee" } }
      ]
    }
  ]
}
{% endschema %}
