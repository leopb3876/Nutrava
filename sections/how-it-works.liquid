<section class="sn-section">
  <div class="sn-section__head">
    <h2 class="sn-section__title">{{ section.settings.heading }}</h2>
    {%- if section.settings.subheading != blank -%}
      <p class="sn-section__sub">{{ section.settings.subheading }}</p>
    {%- endif -%}
  </div>

  <div class="sn-steps">
    {%- for block in section.blocks -%}
      <div class="sn-step" {{ block.shopify_attributes }}>
        <span class="sn-step__num">{{ forloop.index | prepend: '0' | slice: -2, 2 }}</span>
        <div class="sn-step__visual">
          {%- case forloop.index -%}
          {%- when 1 -%}
            <svg viewBox="0 0 200 200" fill="none" aria-hidden="true">
              <circle cx="100" cy="100" r="78" stroke="#0F1010" stroke-width="2"/>
              <path d="M70 100h60M100 70v60" stroke="#0F1010" stroke-width="2" stroke-linecap="round"/>
              <circle cx="100" cy="100" r="40" stroke="#0F1010" stroke-width="2" stroke-dasharray="4 6"/>
            </svg>
          {%- when 2 -%}
            <svg viewBox="0 0 200 200" fill="none" aria-hidden="true">
              <rect x="50" y="40" width="40" height="120" rx="20" stroke="#0F1010" stroke-width="2"/>
              <rect x="110" y="60" width="40" height="100" rx="20" stroke="#0F1010" stroke-width="2"/>
              <rect x="58" y="58" width="24" height="6" rx="3" fill="#0F1010"/>
              <rect x="118" y="78" width="24" height="6" rx="3" fill="#0F1010"/>
            </svg>
          {%- else -%}
            <svg viewBox="0 0 200 200" fill="none" aria-hidden="true">
              <path d="M40 130c30-50 90-50 120 0" stroke="#0F1010" stroke-width="2" stroke-linecap="round"/>
              <circle cx="100" cy="80" r="22" stroke="#0F1010" stroke-width="2"/>
              <path d="M88 80l8 8 16-16" stroke="#0F1010" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          {%- endcase -%}
        </div>
        <h3 class="sn-step__title">{{ block.settings.title }}</h3>
        <p class="sn-step__text">{{ block.settings.text }}</p>
      </div>
    {%- endfor -%}
  </div>
</section>

<style>
  .sn-steps {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    max-width: var(--sn-w-page);
    margin: 0 auto;
  }
  .sn-step {
    background: var(--sn-cream);
    border-radius: var(--sn-r-card);
    padding: 32px;
    position: relative;
    overflow: hidden;
    aspect-ratio: 4 / 4.5;
    display: flex;
    flex-direction: column;
    transition: transform .25s ease;
  }
  .sn-step:nth-child(2) { background: var(--sn-lilac); }
  .sn-step:nth-child(3) { background: var(--sn-peach); }
  .sn-step:hover { transform: translateY(-3px); }
  .sn-step__num {
    background: var(--sn-paper);
    color: var(--sn-ink);
    border-radius: var(--sn-r-pill);
    padding: 6px 14px;
    font-size: 12px;
    font-weight: 600;
    align-self: flex-start;
    letter-spacing: 0.04em;
  }
  .sn-step__visual {
    flex: 1;
    margin: 24px 0;
    border-radius: 18px;
    display: grid; place-items: center;
    background: rgba(255,255,255,0.55);
    position: relative;
  }
  .sn-step__visual svg { width: 65%; height: auto; }
  .sn-step__title {
    font-family: var(--sn-display);
    font-size: 26px;
    font-weight: 500;
    letter-spacing: -0.025em;
    line-height: 1.1;
    margin-bottom: 8px;
  }
  .sn-step__text {
    font-size: 14.5px;
    color: var(--sn-ink-soft);
    letter-spacing: -0.005em;
    line-height: 1.5;
  }

  @media (max-width: 980px) {
    .sn-steps { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 640px) {
    .sn-steps { grid-template-columns: 1fr; }
    .sn-step { aspect-ratio: auto; min-height: 380px; }
  }
</style>

{% schema %}
{
  "name": "How It Works",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "A routine matched to your skin" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Three quick steps and you're matched with a routine that's built around your specific skin — not the average customer." }
  ],
  "max_blocks": 3,
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        { "type": "text", "id": "title", "label": "Title" },
        { "type": "textarea", "id": "text", "label": "Description" }
      ]
    }
  ],
  "presets": [
    {
      "name": "How It Works",
      "blocks": [
        { "type": "step", "settings": { "title": "Take the quiz", "text": "7 quick questions about your skin type, top concern, current habits, and what you avoid." } },
        { "type": "step", "settings": { "title": "Get your routine", "text": "A 2–4 product Nutrava routine matched to your profile, with clear AM/PM instructions." } },
        { "type": "step", "settings": { "title": "See the difference", "text": "Most people notice visible results in 2–4 weeks of consistent use. Full results compound over 6–8 weeks." } }
      ]
    }
  ]
}
{% endschema %}
