<section class="how-it-works section-padding bg-white" data-fade-in>
  <div class="container">
    <div class="section-head">
      <h2>{{ section.settings.heading }}</h2>
      {% if section.settings.subheading != blank %}
        <p>{{ section.settings.subheading }}</p>
      {% endif %}
    </div>

    <div class="how-it-works__steps">
      {%- for block in section.blocks -%}
        <div class="how-it-works__step" {{ block.shopify_attributes }}>
          {% if block.settings.image != blank %}
            <div class="how-it-works__photo">
              <img src="{{ block.settings.image | image_url: width: 400 }}" alt="{{ block.settings.image.alt | default: block.settings.title }}" loading="lazy" width="400">
              <span class="how-it-works__num-overlay">{{ forloop.index }}</span>
            </div>
          {% else %}
            <div class="how-it-works__number">{{ forloop.index }}</div>
          {% endif %}
          <h3 class="how-it-works__title">{{ block.settings.title }}</h3>
          <p class="how-it-works__text">{{ block.settings.text }}</p>
        </div>

        {%- unless forloop.last -%}
          <div class="how-it-works__connector" aria-hidden="true">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M9 18l6-6-6-6"/>
            </svg>
          </div>
        {%- endunless -%}
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
  .how-it-works__steps {
    display: flex;
    align-items: flex-start;
    justify-content: center;
    gap: var(--space-lg);
  }

  .how-it-works__step {
    flex: 1;
    max-width: 280px;
    text-align: center;
  }

  .how-it-works__number {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: var(--color-mint-mist);
    color: var(--color-primary);
    font-family: var(--font-heading);
    font-size: 1.25rem;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto var(--space-md);
    font-weight: 600;
  }

  .how-it-works__photo {
    position: relative;
    width: 180px;
    height: 180px;
    margin: 0 auto 20px;
    border-radius: 50%;
    overflow: hidden;
    border: 3px solid var(--color-fern);
  }

  .how-it-works__photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .how-it-works__num-overlay {
    position: absolute;
    bottom: 8px;
    right: 8px;
    width: 36px;
    height: 36px;
    background: var(--color-primary);
    color: #fff;
    border-radius: 50%;
    font-family: var(--font-heading);
    font-size: 1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 2px 8px rgba(0,0,0,0.15);
  }

  .how-it-works__title {
    font-size: 1.125rem;
    margin-bottom: var(--space-sm);
  }

  .how-it-works__text {
    font-size: 14px;
    color: var(--color-text-muted);
    line-height: 1.6;
  }

  .how-it-works__connector {
    display: flex;
    align-items: center;
    color: var(--color-fern);
    opacity: 0.5;
    flex-shrink: 0;
    padding-top: 80px;
  }

  @media (max-width: 768px) {
    .how-it-works__steps {
      flex-direction: column;
      align-items: center;
    }

    .how-it-works__connector {
      transform: rotate(90deg);
      padding-top: 0;
    }

    .how-it-works__photo {
      width: 140px;
      height: 140px;
    }
  }
</style>

{% schema %}
{
  "name": "How It Works",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "How Nutrava Works"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Three simple steps to a routine that actually fits"
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Step image (shown as circle photo)"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Description"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "How It Works",
      "blocks": [
        {
          "type": "step",
          "settings": {
            "title": "Take the Quiz",
            "text": "Answer quick questions about your skin type, concerns, and current routine. Under 60 seconds."
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "Get Your Routine",
            "text": "We match you with a personalised 2\u20134 product routine built for your skin — Essential, Recommended, or Complete."
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "Feel the Difference",
            "text": "Most people feel a difference within the first two weeks of consistent daily use."
          }
        }
      ]
    }
  ]
}
{% endschema %}
