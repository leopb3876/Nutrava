<footer class="sn-footer">
  <div class="sn-footer__grid">
    <div class="sn-footer__brand">
      <h3 class="sn-footer__brand-name">{{ section.settings.brand_name | default: shop.name }}</h3>
      <p class="sn-footer__brand-desc">{{ section.settings.brand_desc }}</p>
    </div>

    {%- for block in section.blocks -%}
      {%- if block.type == 'column' -%}
        <div class="sn-footer__col" {{ block.shopify_attributes }}>
          <h4 class="sn-footer__col-title">{{ block.settings.title }}</h4>
          <ul>
            {%- for i in (1..5) -%}
              {%- assign label_key = 'link_' | append: i | append: '_label' -%}
              {%- assign url_key = 'link_' | append: i | append: '_url' -%}
              {%- assign label = block.settings[label_key] -%}
              {%- assign url = block.settings[url_key] -%}
              {%- if label != blank -%}
                <li><a href="{{ url | default: '#' }}">{{ label }}</a></li>
              {%- endif -%}
            {%- endfor -%}
          </ul>
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>
  <div class="sn-footer__bottom">
    {%- assign current_year = 'now' | date: '%Y' -%}
    <span>{{ section.settings.copyright | replace: '{year}', current_year | default: '© Nutrava — Made in the USA' }}</span>
    <span>{{ section.settings.legal_links | default: 'Privacy · Terms · Accessibility' }}</span>
  </div>
</footer>

<style>
  .sn-footer {
    background: var(--sn-ink);
    color: var(--sn-paper);
    padding: 64px 32px 32px;
    margin-top: 80px;
  }
  .sn-footer__grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 48px;
    max-width: var(--sn-w-page);
    margin: 0 auto;
    padding-bottom: 48px;
    border-bottom: 1px solid rgba(255,255,255,0.12);
  }
  .sn-footer__brand-name {
    font-family: var(--sn-display);
    font-size: 36px;
    font-weight: 500;
    letter-spacing: -0.03em;
    margin-bottom: 16px;
    color: var(--sn-paper);
  }
  .sn-footer__brand-desc {
    color: rgba(255,255,255,0.6);
    font-size: 14.5px;
    max-width: 320px;
    line-height: 1.6;
  }
  .sn-footer__col-title {
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 600;
    color: rgba(255,255,255,0.6);
    margin-bottom: 18px;
    font-family: var(--sn-ui);
  }
  .sn-footer__col ul {
    display: flex;
    flex-direction: column;
    gap: 10px;
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .sn-footer__col a {
    font-size: 14.5px;
    color: rgba(255,255,255,0.85);
    transition: color .15s;
    text-decoration: none;
  }
  .sn-footer__col a:hover { color: var(--sn-paper); }
  .sn-footer__bottom {
    max-width: var(--sn-w-page);
    margin: 24px auto 0;
    display: flex;
    justify-content: space-between;
    font-size: 13px;
    color: rgba(255,255,255,0.5);
  }

  @media (max-width: 980px) {
    .sn-footer__grid { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 640px) {
    .sn-footer__grid { grid-template-columns: 1fr; gap: 32px; }
    .sn-footer__bottom { flex-direction: column; gap: 8px; }
  }
</style>

{% schema %}
{
  "name": "Footer",
  "max_blocks": 4,
  "settings": [
    { "type": "text", "id": "brand_name", "label": "Brand name", "default": "Nutrava" },
    { "type": "textarea", "id": "brand_desc", "label": "Brand description", "default": "Personalised clean skincare, built around your skin. Never tested on animals. Always real percentages." },
    { "type": "text", "id": "copyright", "label": "Copyright text", "default": "© 2026 Nutrava — Made in the USA" },
    { "type": "text", "id": "legal_links", "label": "Legal links text", "default": "Privacy · Terms · Accessibility" }
  ],
  "blocks": [
    {
      "type": "column",
      "name": "Link column",
      "settings": [
        { "type": "text", "id": "title", "label": "Column title" },
        { "type": "text", "id": "link_1_label", "label": "Link 1 label" },
        { "type": "url", "id": "link_1_url", "label": "Link 1 URL" },
        { "type": "text", "id": "link_2_label", "label": "Link 2 label" },
        { "type": "url", "id": "link_2_url", "label": "Link 2 URL" },
        { "type": "text", "id": "link_3_label", "label": "Link 3 label" },
        { "type": "url", "id": "link_3_url", "label": "Link 3 URL" },
        { "type": "text", "id": "link_4_label", "label": "Link 4 label" },
        { "type": "url", "id": "link_4_url", "label": "Link 4 URL" },
        { "type": "text", "id": "link_5_label", "label": "Link 5 label" },
        { "type": "url", "id": "link_5_url", "label": "Link 5 URL" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Footer",
      "blocks": [
        { "type": "column", "settings": { "title": "Shop", "link_1_label": "All products", "link_1_url": "/collections/all", "link_2_label": "Routines", "link_2_url": "/collections/all", "link_3_label": "Best sellers", "link_3_url": "/collections/all", "link_4_label": "The Quiz", "link_4_url": "/pages/quiz" } },
        { "type": "column", "settings": { "title": "Company", "link_1_label": "Our story", "link_1_url": "/pages/about", "link_2_label": "Ingredients", "link_2_url": "/pages/about", "link_3_label": "Journal", "link_3_url": "/blogs/news", "link_4_label": "Contact", "link_4_url": "/pages/contact" } },
        { "type": "column", "settings": { "title": "Help", "link_1_label": "Shipping", "link_1_url": "/pages/shipping", "link_2_label": "Returns", "link_2_url": "/pages/shipping", "link_3_label": "FAQ", "link_3_url": "/pages/about", "link_4_label": "Account", "link_4_url": "/account" } }
      ]
    }
  ]
}
{% endschema %}
