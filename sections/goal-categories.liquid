<section class="goals section-padding" data-fade-in>
  <div class="container">
    <h2 class="text-center mb-xl">{{ section.settings.heading }}</h2>

    <div class="goals__grid">
      {%- for block in section.blocks -%}
        <a href="/pages/quiz" class="goals__card" {{ block.shopify_attributes }}>
          {% if block.settings.image != blank %}
            <div class="goals__image">
              <img src="{{ block.settings.image | image_url: width: 200 }}" alt="{{ block.settings.image.alt | default: block.settings.title }}" width="80" height="80" loading="lazy">
            </div>
          {% else %}
            <span class="goals__icon"><i data-lucide="{{ block.settings.icon }}"></i></span>
          {% endif %}
          <h3 class="goals__title">{{ block.settings.title }}</h3>
          <p class="goals__desc">{{ block.settings.description }}</p>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
  .goals__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: var(--space-md);
  }

  .goals__card {
    background: var(--color-card-bg);
    border: 1.5px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-xl);
    text-align: center;
    text-decoration: none;
    transition: all var(--transition-base);
  }

  .goals__card:hover {
    border-color: var(--color-primary);
    background: var(--color-mint-mist);
    transform: translateY(-2px);
    box-shadow: var(--shadow-hover);
  }

  .goals__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: var(--space-md);
    color: var(--color-primary);
  }

  .goals__icon svg {
    width: 32px;
    height: 32px;
    stroke-width: 1.5;
  }

  .goals__image {
    width: 80px;
    height: 80px;
    margin: 0 auto var(--space-md);
    border-radius: 50%;
    overflow: hidden;
  }

  .goals__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .goals__title {
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: var(--space-xs);
  }

  .goals__desc {
    font-size: 13px;
    color: var(--color-text-muted);
    line-height: 1.5;
  }

  @media (max-width: 768px) {
    .goals__grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .goals__card {
      padding: var(--space-lg);
    }
  }
</style>

{% schema %}
{
  "name": "Goal Categories",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Explore Your Goals"
    }
  ],
  "blocks": [
    {
      "type": "goal",
      "name": "Goal",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Goal image (replaces icon if set)"
        },
        {
          "type": "text",
          "id": "icon",
          "label": "Lucide icon name (fallback if no image)",
          "default": "target"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Goal Categories",
      "blocks": [
        { "type": "goal", "settings": { "icon": "brain", "title": "Focus & Study", "description": "Sharpen concentration and mental clarity" } },
        { "type": "goal", "settings": { "icon": "dumbbell", "title": "Gym & Performance", "description": "Build strength and recover faster" } },
        { "type": "goal", "settings": { "icon": "moon", "title": "Sleep & Recovery", "description": "Fall asleep faster, wake refreshed" } },
        { "type": "goal", "settings": { "icon": "zap", "title": "Energy & Stress", "description": "Sustained energy without the crash" } },
        { "type": "goal", "settings": { "icon": "leaf", "title": "Daily Wellness", "description": "Support your overall health daily" } }
      ]
    }
  ]
}
{% endschema %}
