<section class="comparison section-padding bg-white" data-fade-in>
  <div class="container">
    <div class="section-head text-center mb-xl">
      <h2>{{ section.settings.heading | default: 'Nutrava vs. Generic Skincare' }}</h2>
      <p class="text-muted mt-sm">{{ section.settings.subheading | default: 'Why personalised beats the one-size-fits-all aisle' }}</p>
    </div>
    <div class="comparison__wrap">
      <table class="comparison__table">
        <thead>
          <tr>
            <th class="comparison__feature-col"></th>
            <th class="comparison__nutrava-col">
              <span class="comparison__badge">Recommended</span>
              <br><span class="comparison__brand">Nutrava</span>
            </th>
            <th class="comparison__generic-col">Generic Brands</th>
          </tr>
        </thead>
        <tbody>
          {% for block in section.blocks %}
            <tr {{ block.shopify_attributes }}>
              <td class="comparison__feature">{{ block.settings.feature }}</td>
              <td class="comparison__check">
                {% if block.settings.nutrava %}
                  <span class="comparison__icon comparison__icon--yes"><i data-lucide="check"></i></span>
                {% else %}
                  <span class="comparison__icon comparison__icon--no"><i data-lucide="x"></i></span>
                {% endif %}
              </td>
              <td class="comparison__check">
                {% if block.settings.generic %}
                  <span class="comparison__icon comparison__icon--yes"><i data-lucide="check"></i></span>
                {% else %}
                  <span class="comparison__icon comparison__icon--no"><i data-lucide="x"></i></span>
                {% endif %}
              </td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </div>
</section>

<style>
  .comparison__wrap {
    max-width: 700px;
    margin: 0 auto;
    border-radius: 16px;
    overflow: hidden;
    border: 1.5px solid var(--color-border);
    background: #fff;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  .comparison__table {
    width: 100%;
    border-collapse: collapse;
    font-size: 14px;
    min-width: 420px;
  }

  .comparison__table thead tr {
    background: var(--color-dark-section);
  }

  .comparison__feature-col {
    padding: 16px 20px;
    text-align: left;
    color: var(--color-dark-text);
    font-weight: 600;
    width: 40%;
  }

  .comparison__nutrava-col {
    padding: 16px 20px;
    text-align: center;
    width: 30%;
  }

  .comparison__badge {
    display: inline-block;
    background: var(--color-accent);
    color: var(--color-dark-section);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
    padding: 3px 10px;
    border-radius: 4px;
    margin-bottom: 4px;
  }

  .comparison__brand {
    color: var(--color-accent);
    font-family: var(--font-heading);
    font-size: 1.1rem;
  }

  .comparison__generic-col {
    padding: 16px 20px;
    text-align: center;
    color: rgba(245,242,236,0.5);
    font-weight: 500;
    width: 30%;
  }

  .comparison__table tbody tr {
    border-bottom: 1px solid var(--color-border);
  }

  .comparison__table tbody tr:nth-child(even) {
    background: var(--color-bg);
  }

  .comparison__feature {
    padding: 14px 20px;
    color: var(--color-text);
    font-weight: 500;
  }

  .comparison__check {
    padding: 14px 20px;
    text-align: center;
  }

  .comparison__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: 50%;
  }

  .comparison__icon svg {
    width: 16px;
    height: 16px;
  }

  .comparison__icon--yes {
    background: #e6f4ea;
    color: #1e7e34;
  }

  .comparison__icon--no {
    background: #fce8e8;
    color: #d32f2f;
  }

  .comparison__wrap {
    position: relative;
  }

  @media (max-width: 480px) {
    .comparison__wrap::after {
      content: '';
      position: absolute;
      top: 0;
      bottom: 0;
      right: 0;
      width: 30px;
      background: linear-gradient(to left, rgba(255,255,255,0.9), transparent);
      pointer-events: none;
      z-index: 1;
    }
  }
</style>

{% schema %}
{
  "name": "Comparison Table",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Nutrava vs. Generic Skincare"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Why personalised beats the one-size-fits-all aisle"
    }
  ],
  "blocks": [
    {
      "type": "row",
      "name": "Feature Row",
      "settings": [
        {
          "type": "text",
          "id": "feature",
          "label": "Feature name",
          "default": "Clinically effective doses"
        },
        {
          "type": "checkbox",
          "id": "nutrava",
          "label": "Nutrava has this",
          "default": true
        },
        {
          "type": "checkbox",
          "id": "generic",
          "label": "Generic brands have this",
          "default": false
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Comparison Table",
      "blocks": [
        { "type": "row", "settings": { "feature": "Personalised to your goals", "nutrava": true, "generic": false } },
        { "type": "row", "settings": { "feature": "Clinically effective doses", "nutrava": true, "generic": false } },
        { "type": "row", "settings": { "feature": "No proprietary blends", "nutrava": true, "generic": false } },
        { "type": "row", "settings": { "feature": "Third-party lab tested", "nutrava": true, "generic": false } },
        { "type": "row", "settings": { "feature": "Free from fillers & binders", "nutrava": true, "generic": false } },
        { "type": "row", "settings": { "feature": "Transparent ingredient labels", "nutrava": true, "generic": false } }
      ]
    }
  ]
}
{% endschema %}
