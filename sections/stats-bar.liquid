<section class="stats-bar" data-fade-in>
  <div class="container">
    <div class="stats-bar__grid">
      {% for block in section.blocks %}
        <div class="stats-bar__item" {{ block.shopify_attributes }}>
          <div class="stats-bar__icon">
            <i data-lucide="{{ block.settings.icon }}"></i>
          </div>
          <span class="stats-bar__number">{{ block.settings.number }}</span>
          <span class="stats-bar__label">{{ block.settings.label }}</span>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

<style>
  .stats-bar {
    padding: 64px 0;
    background: var(--color-dark-section);
  }

  .stats-bar__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 32px;
    max-width: 1000px;
    margin: 0 auto;
    text-align: center;
  }

  .stats-bar__icon {
    width: 52px;
    height: 52px;
    background: rgba(255,255,255,0.1);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-accent);
    margin: 0 auto 12px;
  }

  .stats-bar__icon svg {
    width: 24px;
    height: 24px;
    stroke-width: 1.75;
  }

  .stats-bar__number {
    display: block;
    font-family: var(--font-heading);
    font-size: 2.5rem;
    color: var(--color-accent);
    line-height: 1.1;
    margin-bottom: 4px;
  }

  .stats-bar__label {
    font-size: 14px;
    color: var(--color-dark-text);
    opacity: 0.7;
  }

  @media (max-width: 768px) {
    .stats-bar {
      padding: 32px 0;
    }

    .stats-bar__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 24px;
    }
  }

  @media (max-width: 480px) {
    .stats-bar__grid {
      grid-template-columns: 1fr;
      gap: 16px;
    }
  }
</style>

{% schema %}
{
  "name": "Stats Bar",
  "settings": [],
  "blocks": [
    {
      "type": "stat",
      "name": "Stat",
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "Lucide icon name",
          "default": "sparkles"
        },
        {
          "type": "text",
          "id": "number",
          "label": "Number / headline",
          "default": "100%"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Science-backed"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Stats Bar",
      "blocks": [
        { "type": "stat", "settings": { "icon": "sparkles", "number": "12", "label": "Formulas across 5 skin concerns" } },
        { "type": "stat", "settings": { "icon": "leaf", "number": "100%", "label": "Cruelty-free, vegan-friendly" } },
        { "type": "stat", "settings": { "icon": "shield-check", "number": "30", "label": "Day money-back guarantee" } },
        { "type": "stat", "settings": { "icon": "truck", "number": "Free", "label": "US shipping over $50" } }
      ]
    }
  ]
}
{% endschema %}
