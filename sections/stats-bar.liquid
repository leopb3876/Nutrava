<section class="sn-stats-card">
  <div class="sn-stats-card__blob"></div>
  <div class="sn-stats-card__blob sn-stats-card__blob--bl"></div>

  {%- if section.settings.heading != blank -%}
    <h2 class="sn-stats-card__title">{{ section.settings.heading }}</h2>
  {%- endif -%}

  <div class="sn-stats-card__grid">
    {%- for block in section.blocks -%}
      <div class="sn-stat" {{ block.shopify_attributes }}>
        <div class="sn-stat__number">{{ block.settings.number }}</div>
        <div class="sn-stat__label">{{ block.settings.label }}</div>
      </div>
    {%- endfor -%}
  </div>
</section>

<style>
  .sn-stats-card {
    background: var(--sn-cream);
    border-radius: var(--sn-r-card-lg);
    padding: 80px 48px;
    margin: 0 32px;
    max-width: var(--sn-w-page);
    margin-left: auto; margin-right: auto;
    position: relative;
    overflow: hidden;
  }
  .sn-stats-card__title {
    font-family: var(--sn-display);
    font-size: clamp(28px, 3.5vw, 44px);
    font-weight: 500;
    text-align: center;
    letter-spacing: -0.03em;
    margin-bottom: 64px;
    line-height: 1.1;
    position: relative;
    z-index: 2;
  }
  .sn-stats-card__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 48px;
    text-align: center;
    position: relative;
    z-index: 2;
  }
  .sn-stat__number {
    font-family: var(--sn-display);
    font-size: clamp(64px, 7vw, 96px);
    font-weight: 500;
    letter-spacing: -0.04em;
    line-height: 1;
    margin-bottom: 14px;
  }
  .sn-stat__label {
    font-size: 15px;
    color: var(--sn-ink-soft);
    font-weight: 500;
    letter-spacing: -0.01em;
    max-width: 22ch;
    margin: 0 auto;
  }
  .sn-stats-card__blob {
    position: absolute;
    top: -40px;
    right: -40px;
    width: 320px; height: 320px;
    background: radial-gradient(circle at 35% 35%, var(--sn-blob-1) 0%, var(--sn-blob-1b) 40%, transparent 72%);
    filter: blur(2px);
    opacity: 0.85;
    pointer-events: none;
  }
  .sn-stats-card__blob--bl {
    top: auto; right: auto;
    bottom: -120px; left: -120px;
    width: 260px; height: 260px;
    background: radial-gradient(circle at 60% 40%, var(--sn-blob-2) 0%, var(--sn-blob-2b) 50%, transparent 75%);
    opacity: 0.55;
  }

  @media (max-width: 980px) {
    .sn-stats-card__grid { grid-template-columns: 1fr; gap: 32px; }
  }
  @media (max-width: 640px) {
    .sn-stats-card { margin: 0 16px; padding: 48px 24px; }
    .sn-stats-card__title { margin-bottom: 40px; }
  }
</style>

{% schema %}
{
  "name": "Stats card",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Skincare that actually fits"
    }
  ],
  "max_blocks": 3,
  "blocks": [
    {
      "type": "stat",
      "name": "Stat",
      "settings": [
        { "type": "text", "id": "number", "label": "Number", "default": "20" },
        { "type": "text", "id": "label", "label": "Label", "default": "Clean formulas across 5 skin concerns" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Stats card",
      "blocks": [
        { "type": "stat", "settings": { "number": "20", "label": "Clean formulas across 5 skin concerns" } },
        { "type": "stat", "settings": { "number": "100%", "label": "Cruelty-free, vegan-friendly, fragrance-flexible" } },
        { "type": "stat", "settings": { "number": "30", "label": "Day money-back guarantee on every routine" } }
      ]
    }
  ]
}
{% endschema %}
