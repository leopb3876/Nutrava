{%- if section.blocks.size > 0 -%}
<div class="sn-topbar" data-announcement-bar>
  <div class="sn-topbar__inner" data-announcement-messages>
    {%- for block in section.blocks -%}
      <div class="sn-topbar__msg{% if forloop.first %} is-active{% endif %}" {{ block.shopify_attributes }}>
        {%- if block.settings.link != blank -%}
          {{ block.settings.text_before }}<a href="{{ block.settings.link }}">{{ block.settings.link_text }}</a>{{ block.settings.text_after }}
        {%- else -%}
          <span>{{ block.settings.text_before }}{{ block.settings.link_text }}{{ block.settings.text_after }}</span>
        {%- endif -%}
      </div>
    {%- endfor -%}
  </div>
</div>
{%- endif -%}

<style>
  .sn-topbar {
    background: var(--sn-cream);
    color: var(--sn-ink);
    text-align: center;
    font-size: 13px;
    letter-spacing: -0.01em;
    padding: 10px 16px;
    border-bottom: 1px solid var(--sn-line);
    position: relative;
    z-index: 101;
  }
  .sn-topbar__inner {
    max-width: var(--sn-w-page);
    margin: 0 auto;
    min-height: 18px;
    position: relative;
  }
  .sn-topbar__msg {
    display: none;
    line-height: 1.4;
  }
  .sn-topbar__msg.is-active { display: block; }
  .sn-topbar a {
    text-decoration: underline;
    text-underline-offset: 3px;
    font-weight: 500;
    color: inherit;
  }
  .sn-topbar a:hover { opacity: 0.7; }
</style>

{% schema %}
{
  "name": "Announcement bar",
  "max_blocks": 5,
  "settings": [],
  "blocks": [
    {
      "type": "message",
      "name": "Message",
      "settings": [
        {
          "type": "text",
          "id": "text_before",
          "label": "Text before link",
          "default": "Launch Special — 20% off your first routine with code "
        },
        {
          "type": "text",
          "id": "link_text",
          "label": "Link text (or plain text if no link)",
          "default": "GLOW20"
        },
        {
          "type": "text",
          "id": "text_after",
          "label": "Text after link",
          "default": ""
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Announcement bar",
      "blocks": [
        { "type": "message" }
      ]
    }
  ]
}
{% endschema %}
