<section class="best-sellers section-padding" data-fade-in>
  <div class="container">
    <div class="best-sellers__head">
      <div class="section-head" style="margin-bottom: 0; text-align: left;">
        <h2>{{ section.settings.heading | default: 'Best Sellers' }}</h2>
        <p>{{ section.settings.subheading | default: 'The products our customers reach for first' }}</p>
      </div>
      <a href="{{ section.settings.view_all_link | default: '/collections/all' }}" class="best-sellers__link">Shop All &rarr;</a>
    </div>

    <div class="best-sellers__grid">
      {%- if section.settings.collection != blank -%}
        {%- for product in collections[section.settings.collection].products limit: 4 -%}
          {% render 'product-card', product: product %}
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..4) -%}
          <div class="card">
            <div class="card__image" style="background: var(--color-mint-mist); aspect-ratio: 1; border-radius: var(--radius-md); display: flex; align-items: center; justify-content: center;">
              <svg width="40" height="56" viewBox="0 0 40 56" fill="none"><rect width="40" height="56" rx="6" fill="rgba(90,122,94,0.15)"/></svg>
            </div>
            <div class="card__body" style="padding: 16px 0 0;">
              <span class="card__tag" style="font-size: 11px; font-weight: 700; letter-spacing: 1px; text-transform: uppercase; color: var(--color-primary);">
                {%- case i -%}{%- when 1 -%}Acne{%- when 2 -%}Hydration{%- when 3 -%}Brightening{%- when 4 -%}Anti-Aging{%- endcase -%}
              </span>
              <h3 class="card__title" style="font-family: var(--font-heading); font-size: 1rem; margin: 4px 0;">
                {%- case i -%}{%- when 1 -%}Charcoal Facial Cleanser{%- when 2 -%}Hyaluronic Acid Serum{%- when 3 -%}Vitamin C Serum{%- when 4 -%}Anti-Aging Moisturizer{%- endcase -%}
              </h3>
              <span class="card__price" style="font-size: 14px; color: var(--color-text-body);">
                {%- case i -%}{%- when 1 -%}$19.90{%- when 2 -%}$30.00{%- when 3 -%}$20.00{%- when 4 -%}$40.00{%- endcase -%}
              </span>
            </div>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

<style>
  .best-sellers__head {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: var(--space-xl);
    gap: var(--space-md);
  }

  .best-sellers__link {
    font-size: 14px;
    font-weight: 600;
    color: var(--color-primary);
    text-decoration: none;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .best-sellers__link:hover {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .best-sellers__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-lg);
  }

  @media (max-width: 768px) {
    .best-sellers__grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .best-sellers__head {
      flex-direction: column;
      align-items: flex-start;
      gap: 8px;
    }
  }

  @media (max-width: 480px) {
    .best-sellers__grid {
      grid-template-columns: 1fr;
      max-width: 320px;
      margin: 0 auto;
    }
  }
</style>

{% schema %}
{
  "name": "Best Sellers",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Best Sellers"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "The products our customers reach for first"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "url",
      "id": "view_all_link",
      "label": "View all link",
      "default": "/collections/all"
    }
  ],
  "presets": [
    {
      "name": "Best Sellers"
    }
  ]
}
{% endschema %}
