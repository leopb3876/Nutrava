<section class="sn-section">
  <div class="sn-section__head">
    <h2 class="sn-section__title">{{ section.settings.heading }}</h2>
    {%- if section.settings.subheading != blank -%}
      <p class="sn-section__sub">{{ section.settings.subheading }}</p>
    {%- endif -%}
  </div>

  <div class="sn-products">
    {%- if section.settings.collection != blank and collections[section.settings.collection].products.size > 0 -%}
      {%- for product in collections[section.settings.collection].products limit: 4 -%}
        {%- assign category = product.type | default: product.tags.first -%}
        <a href="{{ product.url }}" class="sn-product">
          <div class="sn-product__visual">
            {%- if product.featured_image -%}
              <img src="{{ product.featured_image | image_url: width: 400 }}" alt="{{ product.featured_image.alt | escape }}" loading="lazy" width="200" height="200">
            {%- else -%}
              <div class="sn-product__bottle" data-label="{{ product.title }}"></div>
            {%- endif -%}
          </div>
          {%- if category != blank -%}
            <span class="sn-product__cat">{{ category }}</span>
          {%- endif -%}
          <h3 class="sn-product__title">{{ product.title }}</h3>
          {%- if product.description != blank -%}
            <p class="sn-product__desc">{{ product.description | strip_html | truncate: 80 }}</p>
          {%- endif -%}
          <div class="sn-product__row">
            <span class="sn-product__price">{{ product.price | money_without_trailing_zeros }}</span>
            <button class="sn-product__add" aria-label="Add {{ product.title }} to cart" type="button" data-add-to-cart data-variant-id="{{ product.selected_or_first_available_variant.id }}">+</button>
          </div>
        </a>
      {%- endfor -%}
    {%- else -%}
      {%- for block in section.blocks -%}
        <a href="{{ block.settings.link | default: '/collections/all' }}" class="sn-product" {{ block.shopify_attributes }}>
          <div class="sn-product__visual">
            <div class="sn-product__bottle" data-label="{{ block.settings.title }}"></div>
          </div>
          <span class="sn-product__cat">{{ block.settings.category }}</span>
          <h3 class="sn-product__title">{{ block.settings.title }}</h3>
          <p class="sn-product__desc">{{ block.settings.description }}</p>
          <div class="sn-product__row">
            <span class="sn-product__price">{{ block.settings.price }}</span>
            <span class="sn-product__add" aria-hidden="true">+</span>
          </div>
        </a>
      {%- endfor -%}
    {%- endif -%}
  </div>
</section>

<style>
  /* Product card styles are shared with the collection page — see assets/selfnamed.css */
</style>

{% schema %}
{
  "name": "Best Sellers",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Best sellers" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "The formulas customers reach for first — and reorder." },
    { "type": "collection", "id": "collection", "label": "Collection (overrides manual blocks)" }
  ],
  "max_blocks": 4,
  "blocks": [
    {
      "type": "manual_product",
      "name": "Manual product",
      "settings": [
        { "type": "text", "id": "category", "label": "Category", "default": "Brightening" },
        { "type": "text", "id": "title", "label": "Title", "default": "Vitamin C Serum" },
        { "type": "text", "id": "description", "label": "Description", "default": "Triple-form vitamin C for tone correction." },
        { "type": "text", "id": "price", "label": "Price", "default": "$40" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Best Sellers",
      "blocks": [
        { "type": "manual_product", "settings": { "category": "Brightening", "title": "Vitamin C Serum", "description": "Triple-form vitamin C for tone correction.", "price": "$40" } },
        { "type": "manual_product", "settings": { "category": "Pores · Oil", "title": "Niacinamide Gel", "description": "Refines pores and balances oil.", "price": "$19" } },
        { "type": "manual_product", "settings": { "category": "Daily Essential", "title": "Moisturising Day Cream", "description": "Daily hydration, layers under SPF.", "price": "$22" } },
        { "type": "manual_product", "settings": { "category": "Daily SPF", "title": "Sunscreen SPF30", "description": "No white cast, no sticky finish.", "price": "$24" } }
      ]
    }
  ]
}
{% endschema %}
