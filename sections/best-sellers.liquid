<section class="sn-section">
  <div class="sn-section__head">
    <h2 class="sn-section__title">{{ section.settings.heading }}</h2>
    {%- if section.settings.subheading != blank -%}
      <p class="sn-section__sub">{{ section.settings.subheading }}</p>
    {%- endif -%}
  </div>

  <div class="sn-products">
    {%- if section.settings.collection != blank and collections[section.settings.collection].products.size > 0 -%}
      {%- for product in collections[section.settings.collection].products limit: 4 -%}
        {%- assign category = product.type | default: product.tags.first -%}
        <a href="{{ product.url }}" class="sn-product">
          <div class="sn-product__visual">
            {%- if product.featured_image -%}
              <img src="{{ product.featured_image | image_url: width: 400 }}" alt="{{ product.featured_image.alt | escape }}" loading="lazy" width="200" height="200">
            {%- else -%}
              <div class="sn-product__bottle" data-label="{{ product.title }}"></div>
            {%- endif -%}
          </div>
          {%- if category != blank -%}
            <span class="sn-product__cat">{{ category }}</span>
          {%- endif -%}
          <h3 class="sn-product__title">{{ product.title }}</h3>
          {%- if product.description != blank -%}
            <p class="sn-product__desc">{{ product.description | strip_html | truncate: 80 }}</p>
          {%- endif -%}
          <div class="sn-product__row">
            <span class="sn-product__price">{{ product.price | money_without_trailing_zeros }}</span>
            <button class="sn-product__add" aria-label="Add {{ product.title }} to cart" type="button" data-add-to-cart data-variant-id="{{ product.selected_or_first_available_variant.id }}">+</button>
          </div>
        </a>
      {%- endfor -%}
    {%- else -%}
      {%- for block in section.blocks -%}
        <a href="{{ block.settings.link | default: '/collections/all' }}" class="sn-product" {{ block.shopify_attributes }}>
          <div class="sn-product__visual">
            <div class="sn-product__bottle" data-label="{{ block.settings.title }}"></div>
          </div>
          <span class="sn-product__cat">{{ block.settings.category }}</span>
          <h3 class="sn-product__title">{{ block.settings.title }}</h3>
          <p class="sn-product__desc">{{ block.settings.description }}</p>
          <div class="sn-product__row">
            <span class="sn-product__price">{{ block.settings.price }}</span>
            <span class="sn-product__add" aria-hidden="true">+</span>
          </div>
        </a>
      {%- endfor -%}
    {%- endif -%}
  </div>
</section>

<style>
  .sn-products {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 18px;
    max-width: var(--sn-w-page);
    margin: 0 auto;
  }
  .sn-product {
    background: var(--sn-cream);
    border-radius: var(--sn-r-card);
    padding: 22px;
    transition: transform .25s ease;
    display: flex; flex-direction: column;
    color: inherit;
    text-decoration: none;
  }
  .sn-product:nth-child(2) { background: var(--sn-lilac); }
  .sn-product:nth-child(3) { background: var(--sn-peach); }
  .sn-product:nth-child(4) { background: var(--sn-sage); }
  .sn-product:hover { transform: translateY(-3px); }
  .sn-product__visual {
    aspect-ratio: 1;
    border-radius: 18px;
    background: rgba(255,255,255,0.55);
    margin-bottom: 18px;
    display: grid; place-items: center;
    position: relative;
    overflow: hidden;
  }
  .sn-product__visual img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .sn-product__bottle {
    width: 60%;
    aspect-ratio: 0.5;
    background: linear-gradient(180deg, rgba(255,255,255,0.8) 0%, rgba(255,255,255,0.5) 100%);
    border-radius: 22px 22px 12px 12px;
    border: 1px solid rgba(15,16,16,0.08);
    position: relative;
  }
  .sn-product__bottle::before {
    content: "";
    position: absolute;
    top: -16px; left: 50%;
    transform: translateX(-50%);
    width: 38%; height: 18px;
    background: var(--sn-ink);
    border-radius: 4px 4px 2px 2px;
  }
  .sn-product__bottle::after {
    content: attr(data-label);
    position: absolute;
    top: 38%; left: 50%; transform: translateX(-50%);
    width: 75%;
    background: var(--sn-paper);
    border-radius: 2px;
    padding: 8px 4px;
    font-family: var(--sn-display);
    font-size: 9px;
    font-weight: 600;
    text-align: center;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--sn-ink);
    line-height: 1.3;
    box-shadow: 0 0 0 1px rgba(15,16,16,0.05);
  }
  .sn-product__cat {
    font-size: 11px; font-weight: 600;
    letter-spacing: 0.06em; text-transform: uppercase;
    color: var(--sn-ink-soft);
    margin-bottom: 6px;
  }
  .sn-product__title {
    font-family: var(--sn-display);
    font-size: 19px;
    font-weight: 500;
    letter-spacing: -0.02em;
    line-height: 1.15;
    margin-bottom: 4px;
  }
  .sn-product__desc {
    font-size: 13px;
    color: var(--sn-ink-soft);
    line-height: 1.5;
    margin-bottom: 18px;
  }
  .sn-product__row {
    display: flex; justify-content: space-between; align-items: center;
    margin-top: auto;
  }
  .sn-product__price {
    font-family: var(--sn-display);
    font-size: 22px;
    font-weight: 600;
    letter-spacing: -0.02em;
  }
  .sn-product__add {
    width: 36px; height: 36px;
    border-radius: 50%;
    background: var(--sn-ink);
    color: var(--sn-paper);
    display: grid; place-items: center;
    transition: transform .15s;
    border: none;
    font-size: 18px;
    cursor: pointer;
  }
  .sn-product__add:hover { transform: scale(1.08); }

  @media (max-width: 980px) {
    .sn-products { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 480px) {
    .sn-products { grid-template-columns: 1fr; max-width: 360px; margin: 0 auto; }
  }
</style>

{% schema %}
{
  "name": "Best Sellers",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Best sellers" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "The formulas customers reach for first — and reorder." },
    { "type": "collection", "id": "collection", "label": "Collection (overrides manual blocks)" }
  ],
  "max_blocks": 4,
  "blocks": [
    {
      "type": "manual_product",
      "name": "Manual product",
      "settings": [
        { "type": "text", "id": "category", "label": "Category", "default": "Brightening" },
        { "type": "text", "id": "title", "label": "Title", "default": "Vitamin C Serum" },
        { "type": "text", "id": "description", "label": "Description", "default": "Triple-form vitamin C for tone correction." },
        { "type": "text", "id": "price", "label": "Price", "default": "$40" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Best Sellers",
      "blocks": [
        { "type": "manual_product", "settings": { "category": "Brightening", "title": "Vitamin C Serum", "description": "Triple-form vitamin C for tone correction.", "price": "$40" } },
        { "type": "manual_product", "settings": { "category": "Pores · Oil", "title": "Niacinamide Gel", "description": "Refines pores and balances oil.", "price": "$19" } },
        { "type": "manual_product", "settings": { "category": "Daily Essential", "title": "Moisturising Day Cream", "description": "Daily hydration, layers under SPF.", "price": "$22" } },
        { "type": "manual_product", "settings": { "category": "Daily SPF", "title": "Sunscreen SPF30", "description": "No white cast, no sticky finish.", "price": "$24" } }
      ]
    }
  ]
}
{% endschema %}
