<section class="sn-section">
  <div class="sn-section__head">
    <h2 class="sn-section__title">{{ section.settings.heading | default: 'Frequently asked' }}</h2>
    {%- if section.settings.subheading != blank -%}
      <p class="sn-section__sub">{{ section.settings.subheading }}</p>
    {%- endif -%}
  </div>

  <div class="sn-faq">
    {%- for block in section.blocks -%}
      <details class="sn-faq__item"{% if forloop.first and section.settings.first_open %} open{% endif %} {{ block.shopify_attributes }}>
        <summary class="sn-faq__q">
          <span class="sn-faq__q-text">{{ block.settings.question }}</span>
          <span class="sn-faq__icon">+</span>
        </summary>
        <p class="sn-faq__a">{{ block.settings.answer }}</p>
      </details>
    {%- endfor -%}
  </div>
</section>

<style>
  .sn-faq {
    max-width: 760px;
    margin: 0 auto;
    border-top: 1px solid var(--sn-line);
  }
  .sn-faq__item {
    border-bottom: 1px solid var(--sn-line);
    padding: 28px 4px;
    cursor: pointer;
  }
  .sn-faq__item summary { list-style: none; }
  .sn-faq__item summary::-webkit-details-marker { display: none; }
  .sn-faq__q {
    display: flex; justify-content: space-between; align-items: center;
    gap: 24px;
  }
  .sn-faq__q-text {
    font-family: var(--sn-display);
    font-size: 22px;
    font-weight: 500;
    letter-spacing: -0.02em;
    line-height: 1.2;
  }
  .sn-faq__icon {
    width: 36px; height: 36px;
    border-radius: 50%;
    background: var(--sn-cream);
    display: grid; place-items: center;
    flex: none;
    transition: transform .25s, background .25s, color .25s;
    font-size: 18px;
  }
  .sn-faq__item[open] .sn-faq__icon {
    transform: rotate(45deg);
    background: var(--sn-ink);
    color: var(--sn-paper);
  }
  .sn-faq__a {
    margin-top: 14px;
    color: var(--sn-ink-soft);
    font-size: 15.5px;
    line-height: 1.6;
    max-width: 60ch;
  }

  @media (max-width: 640px) {
    .sn-faq__q-text { font-size: 18px; }
  }
</style>

{% schema %}
{
  "name": "Home FAQ",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Frequently asked" },
    { "type": "text", "id": "subheading", "label": "Subheading" },
    { "type": "checkbox", "id": "first_open", "label": "Open first item by default", "default": true }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "FAQ",
      "settings": [
        { "type": "text", "id": "question", "label": "Question" },
        { "type": "textarea", "id": "answer", "label": "Answer" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Home FAQ",
      "blocks": [
        { "type": "faq", "settings": { "question": "How does the personalised quiz work?", "answer": "Our quiz takes about 60 seconds. It branches based on your answers — your skin type, top concern, current routine, and sensitivity — and matches you with a 2–4 product routine engineered for your skin profile." } },
        { "type": "faq", "settings": { "question": "How long until I see results?", "answer": "Hydration and calming products feel different on day one. Brightening and anti-aging actives need 2–4 weeks of consistent use, with full benefits compounding over 6–8 weeks." } },
        { "type": "faq", "settings": { "question": "Are your formulas vegan and cruelty-free?", "answer": "100% cruelty-free, never tested on animals, and the vast majority are vegan. Every product page lists the full INCI ingredient list so you can check." } },
        { "type": "faq", "settings": { "question": "What's the return policy?", "answer": "Free US shipping on orders over $50, and a 30-day money-back guarantee on every routine. If it doesn't work for your skin, we refund you, no questions asked." } }
      ]
    }
  ]
}
{% endschema %}
