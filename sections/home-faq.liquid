<section class="home-faq-section section-padding bg-white" data-fade-in>
  <div class="container" style="max-width: 750px;">
    <div class="section-head text-center mb-xl">
      <h2>{{ section.settings.heading | default: 'Frequently Asked Questions' }}</h2>
      <p class="text-muted mt-sm">{{ section.settings.subheading | default: 'Everything you need to know before getting started' }}</p>
    </div>
    <div class="home-faq__list">
      {% for block in section.blocks %}
        <details class="home-faq__item" {{ block.shopify_attributes }}>
          <summary class="home-faq__question">
            {{ block.settings.question }}
            <span class="home-faq__toggle">+</span>
          </summary>
          <div class="home-faq__answer">{{ block.settings.answer }}</div>
        </details>
      {% endfor %}
    </div>
  </div>
</section>

<style>
  .home-faq__list {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .home-faq__item {
    background: #fff;
    border-radius: 12px;
    border: 1px solid var(--color-border);
  }

  .home-faq__question {
    padding: 20px 24px;
    font-weight: 600;
    color: var(--color-text);
    cursor: pointer;
    list-style: none;
    font-size: 15px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
  }

  .home-faq__question::-webkit-details-marker {
    display: none;
  }

  .home-faq__toggle {
    color: var(--color-primary);
    font-size: 20px;
    transition: transform 0.2s;
    flex-shrink: 0;
  }

  .home-faq__item[open] .home-faq__toggle {
    transform: rotate(45deg);
  }

  .home-faq__answer {
    padding: 0 24px 20px;
    font-size: 14px;
    color: var(--color-text-body);
    line-height: 1.7;
  }
</style>

{% schema %}
{
  "name": "Homepage FAQ",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Frequently Asked Questions"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Everything you need to know before getting started"
    }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "FAQ Item",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "What makes Nutrava different?"
        },
        {
          "type": "textarea",
          "id": "answer",
          "label": "Answer",
          "default": "Nutrava matches you with a skincare routine built for your skin type, concerns, and current habits."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Homepage FAQ",
      "blocks": [
        { "type": "faq", "settings": { "question": "What makes Nutrava different from other skincare brands?", "answer": "Most skincare is a lottery \u2014 you buy what the aisle has. Nutrava matches a routine to your skin type, top concern, sensitivity, and current habits. Every formula is clinically dosed, fragrance-free where it matters, and transparent about what\u2019s inside." } },
        { "type": "faq", "settings": { "question": "How does the personalised quiz work?", "answer": "Our quiz takes under 60 seconds and asks about your skin type, top concern, current routine, and sensitivity. It branches based on your answers and matches you with a 2\u20134 product routine built specifically for your skin." } },
        { "type": "faq", "settings": { "question": "How long until I see results?", "answer": "Hydration and calming products usually feel different on day one. For brightening and anti-aging actives, expect visible improvement in 2\u20134 weeks of consistent use, with full benefits building over 6\u20138 weeks." } },
        { "type": "faq", "settings": { "question": "Can I use these products together?", "answer": "Yes \u2014 every routine is designed to layer. We handle the order and balance so you\u2019re not mixing incompatible actives. A good rule: apply thinnest to thickest, water-based serums before oils, SPF last in the morning." } },
        { "type": "faq", "settings": { "question": "What\u2019s your shipping and returns policy?", "answer": "Free US shipping on orders over $50, delivered within 3\u20135 business days. Every product is covered by our 30-day satisfaction guarantee \u2014 if it doesn\u2019t work for your skin, we\u2019ll refund you, no questions asked." } },
        { "type": "faq", "settings": { "question": "Are your products vegan and cruelty-free?", "answer": "100% cruelty-free, never tested on animals, and the vast majority are vegan. Every product page lists the full INCI ingredient list so you can check for anything you need to avoid." } }
      ]
    }
  ]
}
{% endschema %}
