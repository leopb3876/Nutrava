<section class="spotlight section-padding" data-fade-in>
  <div class="container">
    <div class="section-head text-center mb-xl">
      <h2>{{ section.settings.heading | default: 'Ingredient Spotlight' }}</h2>
      <p class="text-muted mt-sm">{{ section.settings.subheading | default: 'The actives behind our best-selling routines' }}</p>
    </div>
    <div class="spotlight__grid">
      {% for block in section.blocks %}
        <div class="spotlight__card" {{ block.shopify_attributes }}>
          <div class="spotlight__img">
            {% if block.settings.image != blank %}
              <img src="{{ block.settings.image | image_url: width: 128 }}" alt="{{ block.settings.name }}" width="64" height="64" loading="lazy">
            {% else %}
              <i data-lucide="leaf"></i>
            {% endif %}
          </div>
          <div class="spotlight__info">
            <h4 class="spotlight__name">{{ block.settings.name }}</h4>
            <p class="spotlight__dose">{{ block.settings.dose }}</p>
            <p class="spotlight__desc">{{ block.settings.description }}</p>
            {% if block.settings.link != blank %}
              <a href="{{ block.settings.link }}" class="spotlight__link">Learn More &rarr;</a>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

<style>
  .spotlight__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    max-width: 1000px;
    margin: 0 auto;
  }

  .spotlight__card {
    display: flex;
    gap: 20px;
    padding: 28px;
    background: var(--color-bg);
    border-radius: 16px;
    border: 1px solid var(--color-border);
    transition: all 0.25s;
  }

  .spotlight__card:hover {
    border-color: var(--color-primary);
    box-shadow: 0 4px 20px rgba(90,122,94,0.08);
  }

  .spotlight__img {
    width: 64px;
    height: 64px;
    border-radius: 12px;
    overflow: hidden;
    flex-shrink: 0;
    background: var(--color-mint-mist);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-primary);
  }

  .spotlight__img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .spotlight__img svg {
    width: 28px;
    height: 28px;
  }

  .spotlight__name {
    font-family: var(--font-heading);
    font-size: 1rem;
    color: var(--color-text);
    margin-bottom: 4px;
  }

  .spotlight__dose {
    font-size: 13px;
    color: var(--color-accent);
    font-weight: 600;
    margin-bottom: 6px;
  }

  .spotlight__desc {
    font-size: 13px;
    color: var(--color-text-muted);
    line-height: 1.6;
    margin: 0 0 8px;
  }

  .spotlight__link {
    font-size: 13px;
    font-weight: 600;
    color: var(--color-primary);
    text-decoration: none;
  }

  .spotlight__link:hover {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  @media (max-width: 768px) {
    .spotlight__grid {
      grid-template-columns: 1fr;
    }
  }
</style>

{% schema %}
{
  "name": "Ingredient Spotlight",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Ingredient Spotlight"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "The actives behind our best-selling routines"
    }
  ],
  "blocks": [
    {
      "type": "ingredient",
      "name": "Ingredient",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Ingredient image"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Name",
          "default": "Hyaluronic Acid"
        },
        {
          "type": "text",
          "id": "dose",
          "label": "Dose / strength",
          "default": "4 molecular weights"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Holds up to 1,000x its weight in water. Our serum layers four different molecular weights so hydration reaches every depth of the skin."
        },
        {
          "type": "url",
          "id": "link",
          "label": "Learn more link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Ingredient Spotlight",
      "blocks": [
        { "type": "ingredient", "settings": { "name": "Hyaluronic Acid", "dose": "4 molecular weights", "description": "Holds up to 1,000x its weight in water. Our serum layers four different molecular weights so hydration reaches every depth of the skin." } },
        { "type": "ingredient", "settings": { "name": "Vitamin C (L-Ascorbic Acid)", "dose": "Triple-form + ferulic acid", "description": "The gold standard for brightening and antioxidant defence. Fades dark spots, evens tone, and shields skin from daily damage." } },
        { "type": "ingredient", "settings": { "name": "Retinol", "dose": "Encapsulated", "description": "The single most studied anti-aging active. Smooths fine lines and refines texture \u2014 paired with ceramides to protect the barrier." } },
        { "type": "ingredient", "settings": { "name": "Niacinamide", "dose": "10% concentration", "description": "A multitasker that refines pores, evens tone, and strengthens the moisture barrier. Well-tolerated by most skin types." } },
        { "type": "ingredient", "settings": { "name": "Activated Charcoal", "dose": "With aloe & tea tree", "description": "Draws pore-clogging buildup without stripping. The backbone of our Charcoal Cleanser for oily and blemish-prone skin." } }
      ]
    }
  ]
}
{% endschema %}
