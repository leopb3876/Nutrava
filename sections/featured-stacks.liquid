<section class="featured-stacks section-padding" data-fade-in>
  <div class="container">
    <div class="flex-between mb-lg">
      <h2>{{ section.settings.heading }}</h2>
      <a href="{{ section.settings.view_all_link }}" class="featured-stacks__view-all">
        {{ 'general.view_all' | t }} →
      </a>
    </div>

    <div class="featured-stacks__grid">
      {%- if section.settings.collection != blank -%}
        {%- for product in collections[section.settings.collection].products limit: 3 -%}
          <div class="featured-stacks__item">
            {% render 'stack-card', product: product, tag: product.type %}
          </div>
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..3) -%}
          <div class="featured-stacks__item">
            <div class="card stack-card">
              <div class="card__image stack-card__image">
                <div class="stack-card__placeholder">
                  <svg width="40" height="56" viewBox="0 0 40 56" fill="none">
                    <rect width="40" height="56" rx="6" fill="rgba(255,255,255,0.6)"/>
                  </svg>
                </div>
              </div>
              <div class="card__body">
                <span class="card__tag">
                  {%- case i -%}
                    {%- when 1 -%}Focus
                    {%- when 2 -%}Performance
                    {%- when 3 -%}Recovery
                  {%- endcase -%}
                </span>
                <h3 class="card__title">
                  {%- case i -%}
                    {%- when 1 -%}Focus Stack
                    {%- when 2 -%}Gym Stack
                    {%- when 3 -%}Sleep Stack
                  {%- endcase -%}
                </h3>
                <span class="card__price">
                  {%- case i -%}
                    {%- when 1 -%}£29.99
                    {%- when 2 -%}£34.99
                    {%- when 3 -%}£24.99
                  {%- endcase -%}
                </span>
              </div>
            </div>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

<style>
  .featured-stacks__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-lg);
  }

  .featured-stacks__view-all {
    font-size: 14px;
    color: var(--color-primary);
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: color var(--transition-fast);
  }

  .featured-stacks__view-all:hover {
    color: #3D5B40;
  }

  @media (max-width: 768px) {
    .featured-stacks__grid {
      grid-template-columns: 1fr;
      max-width: 400px;
      margin: 0 auto;
    }
  }

  @media (min-width: 769px) and (max-width: 1024px) {
    .featured-stacks__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>

{% schema %}
{
  "name": "Featured Stacks",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Popular Stacks"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "url",
      "id": "view_all_link",
      "label": "View all link",
      "default": "/collections/all"
    }
  ],
  "presets": [
    {
      "name": "Featured Stacks"
    }
  ]
}
{% endschema %}
