<nav class="sn-nav" data-header aria-label="Main navigation">
  <a href="/" class="sn-nav__logo">
    <span class="sn-nav__logo-mark">N</span>
    {{ section.settings.logo_text | default: shop.name }}
  </a>

  <div class="sn-nav__menu sn-hide-mobile">
    <a href="/collections/all">{{ section.settings.menu_1_text | default: 'Shop All' }}</a>
    <a href="/collections/all">{{ section.settings.menu_2_text | default: 'Routines' }}</a>
    <a href="/pages/quiz">{{ section.settings.menu_3_text | default: 'Skin Concerns' }}</a>
    <a href="/pages/quiz">{{ section.settings.menu_4_text | default: 'The Quiz' }}</a>
    <a href="/pages/about">{{ section.settings.menu_5_text | default: 'Journal' }}</a>
  </div>

  <div class="sn-nav__cta">
    <button class="sn-nav__icon-btn sn-hide-mobile" data-search-toggle aria-label="Search">
      <i data-lucide="search"></i>
    </button>
    <button class="sn-nav__icon-btn" data-cart-toggle aria-label="Open cart">
      <i data-lucide="shopping-bag"></i>
      <span class="sn-nav__cart-badge" data-cart-badge>0</span>
    </button>
    <a href="/account" class="sn-nav__icon-btn sn-hide-mobile" aria-label="Account">
      <i data-lucide="user"></i>
    </a>
    <a href="/pages/quiz" class="sn-btn sn-btn--ink sn-btn--sm sn-hide-mobile">Take the Quiz</a>
    <button
      class="sn-nav__menu-toggle sn-hide-desktop"
      data-menu-toggle
      aria-label="Menu"
      aria-expanded="false"
    >
      <span class="sn-nav__hamburger">
        <span></span><span></span><span></span>
      </span>
    </button>
  </div>
</nav>

<div class="sn-mobile-menu" data-mobile-menu aria-hidden="true">
  <nav aria-label="Mobile navigation">
    <ul>
      <li><a href="/pages/quiz">Take the Quiz</a></li>
      <li><a href="/collections/all">Shop All</a></li>
      <li><a href="/pages/about">About</a></li>
      <li><a href="/account">Account</a></li>
    </ul>
  </nav>
</div>

<style>
  .sn-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 18px 32px;
    max-width: var(--sn-w-page);
    margin: 0 auto;
    gap: 24px;
    position: relative;
    z-index: 100;
    background: var(--sn-paper);
  }
  .sn-nav__logo {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: var(--sn-display);
    font-size: 22px;
    font-weight: 600;
    letter-spacing: -0.03em;
    text-decoration: none;
    color: var(--sn-ink);
    text-transform: none;
  }
  .sn-nav__logo-mark {
    width: 28px; height: 28px;
    border-radius: 8px;
    background: var(--sn-ink);
    color: var(--sn-paper);
    display: grid; place-items: center;
    font-size: 16px;
    font-weight: 700;
    font-family: var(--sn-ui);
  }
  .sn-nav__menu {
    display: flex;
    gap: 28px;
    font-size: 14px;
    font-weight: 500;
    letter-spacing: -0.01em;
  }
  .sn-nav__menu a {
    padding: 6px 0;
    transition: opacity .15s;
    color: var(--sn-ink);
    text-decoration: none;
  }
  .sn-nav__menu a:hover { opacity: .55; }
  .sn-nav__cta { display: flex; gap: 10px; align-items: center; }

  .sn-nav__icon-btn {
    background: none;
    border: none;
    cursor: pointer;
    color: var(--sn-ink);
    padding: 6px;
    position: relative;
    display: grid;
    place-items: center;
  }
  .sn-nav__icon-btn:hover { opacity: 0.6; }
  .sn-nav__icon-btn svg { width: 20px; height: 20px; }

  .sn-nav__cart-badge {
    position: absolute;
    top: -2px; right: -2px;
    background: var(--sn-amber);
    color: var(--sn-paper);
    font-size: 10px;
    font-weight: 700;
    border-radius: 999px;
    min-width: 16px;
    height: 16px;
    padding: 0 4px;
    display: grid;
    place-items: center;
    line-height: 1;
  }

  .sn-nav__menu-toggle {
    width: 40px; height: 40px;
    background: none;
    border: none;
    cursor: pointer;
    display: grid;
    place-items: center;
  }
  .sn-nav__hamburger {
    display: flex;
    flex-direction: column;
    gap: 5px;
    width: 22px;
  }
  .sn-nav__hamburger span {
    display: block;
    height: 2px;
    background: var(--sn-ink);
    border-radius: 1px;
    transition: all .25s;
  }
  .sn-nav__menu-toggle[aria-expanded="true"] .sn-nav__hamburger span:nth-child(1) {
    transform: rotate(45deg) translate(5px, 5px);
  }
  .sn-nav__menu-toggle[aria-expanded="true"] .sn-nav__hamburger span:nth-child(2) { opacity: 0; }
  .sn-nav__menu-toggle[aria-expanded="true"] .sn-nav__hamburger span:nth-child(3) {
    transform: rotate(-45deg) translate(5px, -5px);
  }

  .sn-mobile-menu {
    position: fixed;
    top: 0; left: 0; right: 0; bottom: 0;
    background: var(--sn-paper);
    padding: 80px 32px 32px;
    transform: translateX(100%);
    transition: transform .25s;
    z-index: 99;
  }
  .sn-mobile-menu.is-open { transform: translateX(0); }
  .sn-mobile-menu ul {
    display: flex;
    flex-direction: column;
    gap: 24px;
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .sn-mobile-menu a {
    font-family: var(--sn-display);
    font-size: 32px;
    font-weight: 500;
    letter-spacing: -0.03em;
    color: var(--sn-ink);
    text-decoration: none;
  }

  .sn-hide-mobile { display: flex; }
  .sn-hide-desktop { display: none; }

  @media (max-width: 980px) {
    .sn-hide-mobile { display: none !important; }
    .sn-hide-desktop { display: flex !important; }
    .sn-nav { padding: 14px 20px; }
  }
</style>

{% schema %}
{
  "name": "Header",
  "settings": [
    { "type": "text", "id": "logo_text", "label": "Logo text", "default": "Nutrava" },
    { "type": "text", "id": "menu_1_text", "label": "Menu item 1", "default": "Shop All" },
    { "type": "text", "id": "menu_2_text", "label": "Menu item 2", "default": "Routines" },
    { "type": "text", "id": "menu_3_text", "label": "Menu item 3", "default": "Skin Concerns" },
    { "type": "text", "id": "menu_4_text", "label": "Menu item 4", "default": "The Quiz" },
    { "type": "text", "id": "menu_5_text", "label": "Menu item 5", "default": "Journal" }
  ]
}
{% endschema %}
