<section class="testimonials section-padding bg-mint">
  <div class="container">
    <div class="text-center mb-xl">
      <h2>{{ section.settings.heading | default: 'What People Are Saying' }}</h2>
      <p class="text-muted mt-sm">{{ section.settings.subheading | default: 'Real results from real people' }}</p>
    </div>
    <div class="testimonials__grid">
      {% for block in section.blocks %}
        <div class="testimonial-card" {{ block.shopify_attributes }}>
          <div class="testimonial-card__stars">
            {% for i in (1..5) %}
              <i data-lucide="star"></i>
            {% endfor %}
          </div>
          <p class="testimonial-card__text">"{{ block.settings.quote }}"</p>
          <div class="testimonial-card__author">{{ block.settings.author }}</div>
          <div class="testimonial-card__meta">{{ block.settings.meta }}</div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

<style>
  .testimonials__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-lg);
    max-width: 1000px;
    margin: 0 auto;
  }

  .testimonial-card {
    background: var(--color-card-bg);
    border-radius: var(--radius-lg);
    padding: var(--space-xl);
    box-shadow: var(--shadow-card);
  }

  .testimonial-card__stars {
    display: flex;
    gap: 2px;
    margin-bottom: var(--space-md);
    color: #e8b931;
  }

  .testimonial-card__stars svg {
    width: 16px;
    height: 16px;
    fill: #e8b931;
    stroke: #e8b931;
  }

  .testimonial-card__text {
    font-size: 15px;
    color: var(--color-text-body);
    line-height: 1.7;
    margin-bottom: var(--space-md);
    font-style: italic;
  }

  .testimonial-card__author {
    font-size: 14px;
    font-weight: 600;
    color: var(--color-text);
  }

  .testimonial-card__meta {
    font-size: 12px;
    color: var(--color-text-muted);
    margin-top: 2px;
  }

  @media (max-width: 768px) {
    .testimonials__grid {
      grid-template-columns: 1fr;
    }
  }
</style>

{% schema %}
{
  "name": "Testimonials",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What People Are Saying"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Real results from real people"
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "textarea",
          "id": "quote",
          "label": "Quote",
          "default": "The quiz recommended a Focus Stack and it's been a game-changer."
        },
        {
          "type": "text",
          "id": "author",
          "label": "Author name",
          "default": "James T."
        },
        {
          "type": "text",
          "id": "meta",
          "label": "Meta (stack, duration)",
          "default": "Focus Stack — 3 months"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonials",
      "blocks": [
        {
          "type": "testimonial",
          "settings": {
            "quote": "The quiz recommended a Focus Stack and it's been a game-changer for my work. I actually feel sharper by mid-afternoon instead of reaching for more coffee.",
            "author": "James T.",
            "meta": "Focus Stack — 3 months"
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "quote": "I was sceptical about personalised supplements but the quiz nailed my issues. Sleep has improved massively since starting the Sleep & Recovery Stack.",
            "author": "Sophie M.",
            "meta": "Sleep Stack — 6 weeks"
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "quote": "Love that everything is science-backed and the ingredients are clean. The Gym Stack has noticeably improved my recovery between training sessions.",
            "author": "Daniel K.",
            "meta": "Gym Performance Stack — 2 months"
          }
        }
      ]
    }
  ]
}
{% endschema %}
