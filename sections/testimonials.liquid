<section class="social-proof" data-fade-in>
  <div class="container">
    <div class="section-head text-center mb-xl">
      <h2 style="color: var(--color-dark-text);">{{ section.settings.heading | default: 'What People Are Saying' }}</h2>
      <p style="color: rgba(245,242,236,0.7);" class="mt-sm">{{ section.settings.subheading | default: 'Real results from real people' }}</p>
    </div>
  </div>
  <div class="social-proof__ticker-wrap">
    <div class="social-proof__ticker" data-testimonial-ticker>
      {%- for block in section.blocks -%}
        <div class="testimonial" {{ block.shopify_attributes }}>
          <span class="testimonial__stars">&#9733;&#9733;&#9733;&#9733;{% if block.settings.five_stars %}&#9733;{% else %}&#9734;{% endif %}</span>
          <p class="testimonial__text">"{{ block.settings.quote }}"</p>
          <div class="testimonial__footer">
            {% if block.settings.avatar != blank %}
              <img class="testimonial__avatar" src="{{ block.settings.avatar | image_url: width: 96 }}" alt="{{ block.settings.author }}" width="48" height="48" loading="lazy">
            {% else %}
              <div class="testimonial__avatar-placeholder">{{ block.settings.author | slice: 0 }}</div>
            {% endif %}
            <div class="testimonial__info">
              <div class="testimonial__author">{{ block.settings.author }}</div>
              <div class="testimonial__meta">{{ block.settings.meta }}</div>
            </div>
          </div>
        </div>
      {%- endfor -%}
      {%- comment -%} Duplicate for seamless infinite scroll {%- endcomment -%}
      {%- for block in section.blocks -%}
        <div class="testimonial" aria-hidden="true">
          <span class="testimonial__stars">&#9733;&#9733;&#9733;&#9733;{% if block.settings.five_stars %}&#9733;{% else %}&#9734;{% endif %}</span>
          <p class="testimonial__text">"{{ block.settings.quote }}"</p>
          <div class="testimonial__footer">
            {% if block.settings.avatar != blank %}
              <img class="testimonial__avatar" src="{{ block.settings.avatar | image_url: width: 96 }}" alt="{{ block.settings.author }}" width="48" height="48" loading="lazy">
            {% else %}
              <div class="testimonial__avatar-placeholder">{{ block.settings.author | slice: 0 }}</div>
            {% endif %}
            <div class="testimonial__info">
              <div class="testimonial__author">{{ block.settings.author }}</div>
              <div class="testimonial__meta">{{ block.settings.meta }}</div>
            </div>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
  .social-proof {
    padding: 80px 0;
    background: var(--color-dark-section);
    overflow: hidden;
  }

  .social-proof__ticker-wrap {
    overflow: hidden;
    position: relative;
  }

  .social-proof__ticker-wrap::before,
  .social-proof__ticker-wrap::after {
    content: '';
    position: absolute;
    top: 0;
    bottom: 0;
    width: 80px;
    z-index: 2;
    pointer-events: none;
  }

  .social-proof__ticker-wrap::before {
    left: 0;
    background: linear-gradient(90deg, var(--color-dark-section) 0%, transparent 100%);
  }

  .social-proof__ticker-wrap::after {
    right: 0;
    background: linear-gradient(270deg, var(--color-dark-section) 0%, transparent 100%);
  }

  .social-proof__ticker {
    display: flex;
    gap: 24px;
    width: max-content;
    animation: ticker-scroll 60s linear infinite;
  }

  .social-proof__ticker:hover {
    animation-play-state: paused;
  }

  @keyframes ticker-scroll {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  .testimonial {
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 16px;
    padding: 28px;
    width: 340px;
    flex-shrink: 0;
  }

  .testimonial__stars {
    color: var(--color-accent);
    font-size: 16px;
    letter-spacing: 2px;
    margin-bottom: 12px;
    display: block;
  }

  .testimonial__text {
    font-size: 15px;
    color: var(--color-dark-text);
    opacity: 0.9;
    line-height: 1.7;
    margin-bottom: 16px;
    font-style: italic;
  }

  .testimonial__footer {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .testimonial__avatar {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid rgba(255,255,255,0.15);
  }

  .testimonial__avatar-placeholder {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: rgba(255,255,255,0.1);
    border: 2px solid rgba(255,255,255,0.15);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-accent);
    font-family: var(--font-heading);
    font-size: 1.2rem;
    font-weight: 700;
  }

  .testimonial__author {
    font-size: 14px;
    font-weight: 600;
    color: var(--color-dark-text);
  }

  .testimonial__meta {
    font-size: 12px;
    color: var(--color-accent);
  }

  @media (max-width: 768px) {
    .social-proof {
      padding: 48px 0;
    }

    .testimonial {
      width: 280px;
    }
  }
</style>

{% schema %}
