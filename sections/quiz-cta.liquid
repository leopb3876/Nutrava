<section class="sn-dark-section">
  <div class="sn-dark-section__blob-l"></div>
  <div class="sn-dark-section__blob-r"></div>
  <div class="sn-dark-section__inner">
    <h2 class="sn-dark-section__title">{{ section.settings.heading }}</h2>
    <div class="sn-dark-section__cta">
      <a href="/pages/quiz" class="sn-btn sn-btn--paper">{{ section.settings.cta_text }}</a>
      {%- if section.settings.text_link != blank -%}
        <a href="{{ section.settings.text_link_url | default: '/collections/all' }}" class="sn-text-link">{{ section.settings.text_link }}</a>
      {%- endif -%}
    </div>
  </div>
</section>

<style>
  .sn-dark-section {
    background: var(--sn-sage);
    color: var(--sn-ink);
    border-radius: var(--sn-r-card-lg);
    margin: 0 32px;
    max-width: var(--sn-w-page);
    margin-left: auto; margin-right: auto;
    padding: 100px 64px;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .sn-dark-section__inner { position: relative; z-index: 2; }
  .sn-dark-section__title {
    font-family: var(--sn-display);
    font-size: clamp(28px, 3.5vw, 42px);
    font-weight: 500;
    letter-spacing: -0.03em;
    line-height: 1.15;
    max-width: 22ch;
    margin: 0 auto 36px;
  }
  .sn-dark-section__cta {
    display: flex; gap: 16px;
    justify-content: center;
    align-items: center;
    flex-wrap: wrap;
  }
  .sn-dark-section__blob-l,
  .sn-dark-section__blob-r {
    position: absolute;
    pointer-events: none;
    z-index: 1;
    width: 520px; height: 380px;
    border-radius: 50%;
    filter: blur(40px);
  }
  .sn-dark-section__blob-l {
    top: 50%; left: -16%;
    transform: translateY(-50%);
    background: radial-gradient(ellipse at 60% 50%,
      rgba(255, 255, 255, 0.55) 0%,
      rgba(255, 255, 255, 0.25) 35%,
      rgba(255, 255, 255, 0.0) 70%);
    opacity: 0.85;
  }
  .sn-dark-section__blob-r {
    top: 50%; right: -14%;
    transform: translateY(-50%);
    width: 480px; height: 360px;
    background: radial-gradient(ellipse at 35% 50%,
      rgba(248, 229, 201, 0.55) 0%,
      rgba(248, 229, 201, 0.22) 35%,
      rgba(248, 229, 201, 0.0) 70%);
    opacity: 0.85;
  }

  @media (max-width: 640px) {
    .sn-dark-section { margin: 0 16px; padding: 64px 28px; }
  }
</style>

{% schema %}
{
  "name": "Mid-page CTA",
  "settings": [
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "Whether you're starting from scratch or upgrading a 6-step routine, we'll meet you where you are."
    },
    { "type": "text", "id": "cta_text", "label": "Button text", "default": "Start the Quiz" },
    { "type": "text", "id": "text_link", "label": "Secondary text link", "default": "Or browse all products" },
    { "type": "url", "id": "text_link_url", "label": "Secondary link URL" }
  ],
  "presets": [
    { "name": "Mid-page CTA" }
  ]
}
{% endschema %}
