<section class="quiz-cta section-padding" data-fade-in>
  <div class="container">
    <div class="quiz-cta__card" {% if section.settings.background_image != blank %}style="background-image: linear-gradient(135deg, rgba(226,237,218,0.9) 0%, rgba(181,202,165,0.9) 100%), url('{{ section.settings.background_image | image_url: width: 1200 }}'); background-size: cover; background-position: center;"{% endif %}>
      <h2 class="quiz-cta__heading">{{ section.settings.heading }}</h2>
      <p class="quiz-cta__text">{{ section.settings.text }}</p>
      <a href="/pages/quiz" class="btn btn--primary btn--lg">{{ section.settings.cta_text }}</a>
    </div>
  </div>
</section>

<style>
  .quiz-cta__card {
    background: linear-gradient(135deg, var(--color-mint-mist) 0%, var(--color-fern) 100%);
    border-radius: var(--radius-lg);
    padding: var(--space-3xl) var(--space-xl);
    text-align: center;
    max-width: 700px;
    margin: 0 auto;
  }

  .quiz-cta__heading {
    margin-bottom: var(--space-sm);
  }

  .quiz-cta__text {
    font-size: 1rem;
    color: var(--color-text-body);
    margin-bottom: var(--space-xl);
  }
</style>

{% schema %}
{
  "name": "Quiz CTA",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Not sure where to start?"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Take our quiz and we'll match you with a skincare routine built for your skin. Under 60 seconds."
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Button text",
      "default": "Take the Quiz"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image (optional)"
    }
  ],
  "presets": [
    {
      "name": "Quiz CTA"
    }
  ]
}
{% endschema %}
