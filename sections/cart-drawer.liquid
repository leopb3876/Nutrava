<!-- Cart Overlay -->
<div class="cart-overlay" data-cart-overlay></div>

<!-- Cart Drawer -->
<aside class="cart-drawer" data-cart-drawer aria-label="Shopping cart">
  <div class="cart-drawer__header">
    <h2 class="cart-drawer__title">Your Cart</h2>
    <span class="cart-drawer__count" data-cart-count>0 items</span>
    <button class="cart-drawer__close" data-cart-close aria-label="Close cart">
      <i data-lucide="x"></i>
    </button>
  </div>

  <!-- Empty State -->
  <div class="cart-drawer__empty" data-cart-empty>
    <div class="cart-drawer__empty-icon">
      <i data-lucide="shopping-bag"></i>
    </div>
    <p class="cart-drawer__empty-title">Your cart is empty</p>
    <p class="cart-drawer__empty-text">Take the quiz to find your personalised routine.</p>
    <a href="/pages/quiz" class="btn btn--primary">Take the Quiz</a>
  </div>

  <!-- Filled State -->
  <div class="cart-drawer__filled" data-cart-filled style="display: none;">
    <div class="cart-drawer__items" data-cart-items>
      <!-- Cart items rendered by cart.js -->
    </div>

    <div class="cart-drawer__bottom">
      <!-- Cross-Sells -->
      <div class="cart-cross-sells" data-cart-cross-sells style="display: none;">
        <p class="cart-cross-sells__title">Pairs well with your routine</p>
        <div class="cart-cross-sells__grid" data-cross-sell-items></div>
      </div>

      <!-- Subscribe & Save -->
      <div class="cart-subscribe" data-cart-subscribe>
        <div class="cart-subscribe__options">
          <div class="cart-subscribe__option is-active" data-purchase-type="onetime">
            <span class="cart-subscribe__radio"></span>
            <span class="cart-subscribe__text">
              <span class="cart-subscribe__label">One-time purchase</span>
            </span>
          </div>
          <div class="cart-subscribe__option" data-purchase-type="subscribe">
            <span class="cart-subscribe__radio"></span>
            <span class="cart-subscribe__text">
              <span class="cart-subscribe__label">Subscribe & Save</span>
              <span class="cart-subscribe__desc">Delivered on your schedule. Cancel anytime.</span>
            </span>
            <span class="cart-subscribe__badge">15% off</span>
          </div>
        </div>
        <div class="cart-subscribe__frequency" data-subscribe-frequency>
          <select data-frequency-select>
            <option value="30">Every 30 days</option>
            <option value="60">Every 60 days</option>
            <option value="90">Every 90 days</option>
          </select>
        </div>
      </div>

      <div class="cart-drawer__footer">
      <div class="cart-footer__savings" data-cart-savings style="display: none;"></div>
      <div class="cart-drawer__subtotal">
        <span>Subtotal</span>
        <span data-cart-subtotal>{{ cart.currency.symbol | default: '$' }}0.00</span>
      </div>
      {% render 'locale-vars' %}
      <p class="cart-drawer__shipping">{{ free_shipping_text }}</p>
      <p class="cart-drawer__guarantee">
        <i data-lucide="shield-check"></i>
        30-day money-back guarantee
      </p>
      <div class="cart-discount" data-cart-discount>
        <a href="#" class="cart-discount__toggle" data-discount-toggle>Have a promo code?</a>
        <div class="cart-discount__form" data-discount-form style="display: none;">
          <div class="cart-discount__input-wrap">
            <input type="text" class="cart-discount__input" data-discount-input placeholder="Enter code" autocomplete="off">
            <button type="button" class="cart-discount__apply" data-discount-apply>Apply</button>
          </div>
        </div>
        <div class="cart-discount__applied" data-discount-applied style="display: none;">
          <span class="cart-discount__code" data-discount-code></span>
          <button type="button" class="cart-discount__remove" data-discount-remove>Remove</button>
        </div>
      </div>
      <button class="btn btn--primary cart-drawer__checkout" data-cart-checkout>
        Checkout
      </button>
    </div>
    </div>
  </div>
</aside>

<!-- Checkout Auth Overlay -->
<div class="auth-overlay" data-auth-overlay>
  <div class="auth-card" data-auth-card>
    <button class="auth-card__close" data-auth-close aria-label="Close">
      <i data-lucide="x"></i>
    </button>

    <div class="auth-card__header">
      <div class="auth-card__icon">
        <i data-lucide="lock"></i>
      </div>
      <h2>Secure Checkout</h2>
      <p>Sign in to complete your order</p>
    </div>

    <!-- Subscription Summary (shown when Subscribe & Save is active) -->
    <div class="auth-sub-summary" data-auth-sub-summary style="display: none;">
      <div class="auth-sub-summary__icon"><i data-lucide="repeat"></i></div>
      <div class="auth-sub-summary__title">Your Monthly Subscription</div>
      <div class="auth-sub-summary__details" data-auth-sub-details></div>
      <div class="auth-sub-summary__cancel">Cancel or modify anytime</div>
    </div>

    <!-- Social Buttons -->
    <div class="auth-card__social">
      <button type="button" class="auth-social-btn auth-social-btn--google" data-auth-google>
        <svg width="18" height="18" viewBox="0 0 48 48"><path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/><path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/><path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/><path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/></svg>
        Continue with Google
      </button>
      <button type="button" class="auth-social-btn auth-social-btn--apple" data-auth-apple>
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.05 20.28c-.98.95-2.05.88-3.08.4-1.09-.5-2.08-.48-3.24 0-1.44.62-2.2.44-3.06-.4C2.79 15.25 3.51 7.59 9.05 7.31c1.35.07 2.29.74 3.08.8 1.18-.24 2.31-.93 3.57-.84 1.51.12 2.65.72 3.4 1.8-3.12 1.87-2.38 5.98.48 7.13-.57 1.5-1.31 2.99-2.54 4.09zM12.03 7.25c-.15-2.23 1.66-4.07 3.74-4.25.29 2.58-2.34 4.5-3.74 4.25z"/></svg>
        Continue with Apple
      </button>
    </div>

    <div class="auth-card__divider"><span>or</span></div>

    <!-- Sign In Form (default visible) -->
    <form class="auth-form" data-auth-signin>
      <div class="auth-field">
        <label for="auth-email">Email</label>
        <input type="email" id="auth-email" placeholder="you@example.com" required>
      </div>
      <div class="auth-field">
        <label for="auth-password">Password</label>
        <input type="password" id="auth-password" placeholder="••••••••" required>
      </div>
      <button type="submit" class="btn btn--primary auth-form__submit">Sign In & Pay</button>
      <p class="auth-form__switch">New here? <a href="#" data-auth-toggle="signup">Create account</a></p>
    </form>

    <!-- Create Account Form (hidden) -->
    <form class="auth-form" data-auth-signup style="display: none;">
      <div class="auth-field">
        <label for="auth-name">Full Name</label>
        <input type="text" id="auth-name" placeholder="Your name" required>
      </div>
      <div class="auth-field">
        <label for="auth-signup-email">Email</label>
        <input type="email" id="auth-signup-email" placeholder="you@example.com" required>
      </div>
      <div class="auth-field">
        <label for="auth-signup-password">Password</label>
        <input type="password" id="auth-signup-password" placeholder="Create a password" required>
      </div>
      <button type="submit" class="btn btn--primary auth-form__submit">Create Account</button>
      <p class="auth-form__switch">Already have an account? <a href="#" data-auth-toggle="signin">Sign in</a></p>
    </form>

    <!-- Guest Checkout -->
    <div class="auth-card__guest">
      <a href="#" data-auth-guest>Continue as Guest <span>→</span></a>
    </div>
  </div>
</div>

<!-- Product data for cross-sells (used by cart.js on Shopify, ignored in preview) -->
<script type="application/json" id="nutrava-product-data">
  [
    {%- for p in collections.all.products -%}
      {
        "handle": {{ p.handle | json }},
        "title": {{ p.title | json }},
        "price": {{ p.price }},
        "image": {{ p.featured_image | image_url: width: 200 | json }},
        "pairsWith": {{ p.metafields.custom.pairs_with.value | json | default: '[]' }}
      }{%- unless forloop.last -%},{%- endunless -%}
    {%- endfor -%}
  ]
</script>

{% schema %}
{
  "name": "Cart Drawer",
  "settings": []
}
{% endschema %}
