      {%- if size_text != blank %} · {{ size_text }}{%- endif -%}
    </span>
  </div>
  <button
    class="sticky-cta__btn"
    type="button"
    data-sticky-add-to-cart
    data-product-handle="{{ product.handle }}"
    data-product-title="{{ product.title | escape }}"
    data-product-price="{{ product.price }}"
    data-variant-id="{{ product.selected_or_first_available_variant.id }}"
    {% unless product.available %}disabled{% endunless %}
  >
    {%- if product.available -%}Add to cart{%- else -%}Sold out{%- endif -%}
  </button>
</div>

<script>
(function () {
  /* ---------- Analytics: view_item ---------- */
  if (typeof gtag === 'function') gtag('event', 'view_item', { currency: '{{ shop.currency }}', items: [{ item_name: '{{ product.title | escape }}', item_id: '{{ product.handle }}', price: {{ product.price | divided_by: 100.0 }} }] });
  if (typeof fbq === 'function') fbq('track', 'ViewContent', { content_name: '{{ product.title | escape }}', content_ids: ['{{ product.handle }}'], content_type: 'product', value: {{ product.price | divided_by: 100.0 }}, currency: '{{ shop.currency }}' });

  /* ---------- Image gallery: swap main image when thumb clicked ---------- */
  var thumbs = document.querySelectorAll('.gallery__thumb');
  var mainEl = document.getElementById('gallery-main');
  var mainImg = mainEl ? mainEl.querySelector('.gallery__main-img') : null;
  thumbs.forEach(function (t) {
    t.addEventListener('click', function () {
      thumbs.forEach(function (x) { x.classList.remove('is-active'); });
      t.classList.add('is-active');
      var src = t.getAttribute('data-thumb-src');
      if (mainImg && src) {
        mainImg.src = src;
      } else {
        var tint = t.getAttribute('data-thumb');
        mainEl.classList.remove('gallery__main--peach', 'gallery__main--lilac', 'gallery__main--sage');
        if (tint && tint !== 'cream') mainEl.classList.add('gallery__main--' + tint);
      }
    });
  });

  /* ---------- Main ATC: AJAX add via NutravaCart ---------- */
  var mainBtn = document.querySelector('[data-add-to-cart]');
  if (mainBtn && window.NutravaCart) {
    var form = mainBtn.closest('form');
    if (form) {
      form.addEventListener('submit', function (e) {
        e.preventDefault();
        var variantId = form.querySelector('[name="id"]').value;
        NutravaCart.addItem({
          id: parseInt(variantId, 10),
          handle: mainBtn.dataset.productHandle,
          title: mainBtn.dataset.productTitle,
          price: parseInt(mainBtn.dataset.productPrice, 10),
          quantity: 1
        });
      });
    }
  }

  /* ---------- Sticky mobile CTA: show after buy box scrolls out ---------- */
  var bar = document.getElementById('sticky-cta');
  var buyBox = document.getElementById('buy-box');
  if (bar && buyBox && 'IntersectionObserver' in window) {
    var observer = new IntersectionObserver(function (entries) {
      entries.forEach(function (e) { bar.classList.toggle('is-visible', !e.isIntersecting); });
    }, { rootMargin: '0px 0px -40% 0px' });
    observer.observe(buyBox);
  }

  var stickyBtn = document.querySelector('[data-sticky-add-to-cart]');
  if (stickyBtn && window.NutravaCart) {
    stickyBtn.addEventListener('click', function () {
      NutravaCart.addItem({
        id: parseInt(this.dataset.variantId, 10),
        handle: this.dataset.productHandle,
        title: this.dataset.productTitle,
        price: parseInt(this.dataset.productPrice, 10),
        quantity: 1
      });
    });
  }
})();
</script>
