<section class="sn-cart-page">
  <div class="sn-cart-page__inner">
    <h1 class="sn-cart-page__title">Your <em>cart</em></h1>

    {% if cart.item_count == 0 %}
      <p class="sn-cart-page__lead">Nothing here yet — let's find a routine that fits.</p>

      <div class="sn-cart-empty">
        <h2 class="sn-cart-empty__title">Your cart is empty</h2>
        <p class="sn-cart-empty__text">Take the 60-second quiz and we'll match you with a clean routine engineered for your skin.</p>
        <div class="sn-cart-empty__actions">
          <a href="/pages/quiz" class="sn-btn sn-btn--ink">Take the Quiz</a>
          <a href="/collections/all" class="sn-btn sn-btn--ghost">Browse Products</a>
        </div>
      </div>

    {% else %}
      <p class="sn-cart-page__lead">Review your routine, then secure your order.</p>

      <div class="sn-cart-grid">
        <div class="sn-cart-grid__items">
          {% for item in cart.items %}
            <div class="cart-item">
              <div class="cart-item__image">
                {% if item.image %}
                  <img src="{{ item.image | image_url: width: 240 }}" alt="{{ item.image.alt | default: item.title | escape }}" width="120" height="120" loading="lazy">
                {% else %}
                  <div class="cart-item__placeholder">
                    {% render 'icon', name: 'pill' %}
                  </div>
                {% endif %}
              </div>

              <div class="cart-item__details">
                <a href="{{ item.url }}" class="cart-item__title">{{ item.product.title }}</a>
                {% if item.variant.title != 'Default Title' %}
                  <span class="cart-item__variant">{{ item.variant.title }}</span>
                {% endif %}
                <span class="cart-item__price">{{ item.line_price | money }}</span>

                <div class="cart-item__actions">
                  <form action="/cart/change" method="post" class="cart-item__qty">
                    <input type="hidden" name="id" value="{{ item.key }}">
                    <button type="submit" name="quantity" value="{{ item.quantity | minus: 1 }}" class="cart-item__qty-btn" aria-label="Decrease quantity">
                      {% render 'icon', name: 'minus' %}
                    </button>
                    <span class="cart-item__qty-value">{{ item.quantity }}</span>
                    <button type="submit" name="quantity" value="{{ item.quantity | plus: 1 }}" class="cart-item__qty-btn" aria-label="Increase quantity">
                      {% render 'icon', name: 'plus' %}
                    </button>
                  </form>

                  <a href="/cart/change?id={{ item.key }}&quantity=0" class="cart-item__remove">
                    {% render 'icon', name: 'trash-2' %}
                    Remove
                  </a>
                </div>
              </div>
            </div>
          {% endfor %}
        </div>

        <aside class="sn-cart-grid__summary">
          <h2 class="sn-cart-grid__summary-title">Order summary</h2>
          <div class="sn-cart-grid__summary-row">
            <span>Subtotal · {{ cart.item_count }}{% if cart.item_count == 1 %} item{% else %} items{% endif %}</span>
            <span>{{ cart.items_subtotal_price | money }}</span>
          </div>
          {% if cart.total_discount > 0 %}
            <div class="sn-cart-grid__summary-row">
              <span>Discount</span>
              <span>− {{ cart.total_discount | money }}</span>
            </div>
          {% endif %}
          <div class="sn-cart-grid__summary-row sn-cart-grid__summary-row--total">
            <span>Total</span>
            <span>{{ cart.total_price | money }}</span>
          </div>
          {% render 'locale-vars' %}
          <p class="sn-cart-grid__summary-meta">{{ free_shipping_text }}</p>
          <p class="sn-cart-grid__summary-meta">30-day money-back guarantee · Secure checkout</p>

          <a href="/checkout" class="sn-cart-grid__checkout">Proceed to checkout</a>
          <a href="/collections/all" class="sn-cart-grid__continue">← Continue shopping</a>
        </aside>
      </div>
    {% endif %}
  </div>
</section>
