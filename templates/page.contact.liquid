<!-- HERO -->
<section class="sn-page-hero">
  <span class="sn-page-hero__eyebrow">Get in touch</span>
  <h1 class="sn-page-hero__title">Say <em>hello</em>.</h1>
  <p class="sn-page-hero__lead">Have a question about your order, an ingredient, or your quiz match? We read every message and reply within a day.</p>
</section>

<!-- FORM -->
<section class="sn-page-section sn-page-section--narrow">
  <div class="sn-form-card">
    {% form 'contact' %}
      {% if form.posted_successfully? %}
        <div class="sn-form__success">
          <div class="sn-form__success-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          </div>
          <h3 class="sn-form__success-title">Message sent</h3>
          <p class="sn-form__success-text">We'll get back to you within 24 hours.</p>
        </div>
      {% else %}
        <div class="sn-form">
          <div class="sn-form-field">
            <label for="contact-name">Name</label>
            <input type="text" name="contact[name]" id="contact-name" required autocomplete="name">
          </div>
          <div class="sn-form-field">
            <label for="contact-email">Email</label>
            <input type="email" name="contact[email]" id="contact-email" required autocomplete="email">
          </div>
          <div class="sn-form-field">
            <label for="contact-message">Message</label>
            <textarea name="contact[body]" id="contact-message" rows="5" required></textarea>
          </div>
          <button type="submit" class="sn-form__submit">Send message</button>
          <p class="sn-form__hint">
            Check our <a href="/pages/about#faq">FAQ</a> first — your question might already be answered.
          </p>
        </div>
      {% endif %}
    {% endform %}
  </div>

  <div class="sn-contact-chips">
    <div class="sn-contact-chip">
      <div class="sn-contact-chip__icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
      </div>
      <span class="sn-contact-chip__label">Email</span>
      <a href="mailto:hello@hisae.net" class="sn-contact-chip__value">hello@hisae.net</a>
    </div>
    <div class="sn-contact-chip">
      <div class="sn-contact-chip__icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
      </div>
      <span class="sn-contact-chip__label">Response time</span>
      <span class="sn-contact-chip__value">Within 24 hours</span>
    </div>
  </div>
</section>
