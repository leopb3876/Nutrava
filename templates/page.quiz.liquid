{{ 'quiz.css' | asset_url | stylesheet_tag }}


<div class="quiz-shell">

  <!-- ============== HEADER ============== -->
  <header class="quiz-header">
    <div class="quiz-header__nav">
      <button class="quiz-header__btn" id="back-btn" aria-label="Back" disabled>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
      </button>
    </div>
    <a href="/" class="quiz-header__logo">
      <span class="quiz-header__logo-mark">N</span>
      Nutrava
    </a>
    <div class="quiz-header__right">
      <span class="quiz-header__counter" id="counter">Welcome</span>
      <a class="quiz-header__btn" href="/" aria-label="Close quiz and return home">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </a>
    </div>
  </header>

  <!-- ============== PROGRESS BAR ============== -->
  <div class="quiz-progress" aria-hidden="true"><div class="quiz-progress__fill" id="progress-fill"></div></div>

  <!-- ============== STAGE ============== -->
  <div class="quiz-stage">

    <!-- INTRO -->
    <section class="quiz-screen is-active" data-screen="intro">
      <div class="intro">
        <span class="intro__eyebrow"><span class="dot"></span> Personalised clean skincare</span>
        <h1 class="intro__title">Find your routine,<br><em>in 60 seconds.</em></h1>
        <p class="intro__sub">Nine quick questions and we'll match you with a clean skincare routine engineered around your skin type, concerns, age, climate, and current habits.</p>
        <div class="intro__pills">
          <span class="intro__pill">9 questions</span>
          <span class="intro__pill">Free, always</span>
          <span class="intro__pill">Built for your skin</span>
        </div>
        <button class="btn btn--ink btn--lg" data-advance>Begin the quiz</button>
        <p class="intro__reassurance">No account needed. We only ask for your email at the very end.</p>
      </div>
    </section>

    <!-- Q1: SKIN TYPE -->
    <section class="quiz-screen" data-screen="q1">
      <span class="question__overline">Question 1 of 9</span>
      <h2 class="question__title">What's your <em>skin type?</em></h2>
      <p class="question__sub">This is the biggest signal for what your skin actually needs.</p>
      <div class="answers">
        <button class="answer" data-advance="q2">
          <span class="answer__icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/></svg></span>
          <span class="answer__body">
            <span class="answer__title">Oily</span>
            <span class="answer__hint">Shine, large pores, frequent breakouts</span>
          </span>
          <span class="answer__chevron"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg></span>
        </button>
        <button class="answer" data-advance="q2">
          <span class="answer__icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M9.59 4.59A2 2 0 1 1 11 8H2m10.59 11.41A2 2 0 1 0 14 16H2m15.73-8.27A2.5 2.5 0 1 1 19.5 12H2"/></svg></span>
          <span class="answer__body">
            <span class="answer__title">Dry</span>
            <span class="answer__hint">Tight feeling, flaky patches, rough texture</span>
          </span>
          <span class="answer__chevron"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg></span>
        </button>
        <button class="answer" data-advance="q2">
          <span class="answer__icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v18M3 12h18"/></svg></span>
          <span class="answer__body">
            <span class="answer__title">Combination</span>
            <span class="answer__hint">Oily T-zone, dry or normal cheeks</span>
          </span>
          <span class="answer__chevron"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg></span>
        </button>
        <button class="answer" data-advance="q2">
          <span class="answer__icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg></span>
          <span class="answer__body">
            <span class="answer__title">Sensitive</span>
            <span class="answer__hint">Redness, easily irritated, reactive</span>
          </span>
          <span class="answer__chevron"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg></span>
        </button>
        <button class="answer" data-advance="q2">
          <span class="answer__icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3M12 17h.01"/></svg></span>
          <span class="answer__body">
            <span class="answer__title">Normal / I'm not sure</span>
            <span class="answer__hint">No major pattern — we'll figure it out</span>
          </span>
          <span class="answer__chevron"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg></span>
        </button>
      </div>
    </section>

