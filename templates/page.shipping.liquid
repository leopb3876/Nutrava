<section style="padding: 80px 0; background: linear-gradient(180deg, var(--color-mint-mist) 0%, var(--color-bg) 100%); text-align: center;">
  <div class="container container--narrow">
    <span class="label mb-sm" style="display: block;">Delivery & Returns</span>
    <h1 style="font-family: var(--font-heading); font-size: clamp(2rem, 4vw, 2.5rem); color: var(--color-text); margin-bottom: 16px;">Shipping & Returns</h1>
    <p style="font-size: 1rem; color: var(--color-text-body); line-height: 1.6; max-width: 480px; margin: 0 auto;">Everything you need to know about getting your supplements delivered.</p>
  </div>
</section>

<section style="padding: 64px 0;">
  <div class="container" style="max-width: 700px;">
    <!-- Shipping -->
    <div style="margin-bottom: 48px;">
      <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 24px;">
        <div style="width: 40px; height: 40px; background: var(--color-mint-mist); border-radius: 50%; display: flex; align-items: center; justify-content: center; color: var(--color-primary);">
          <i data-lucide="truck"></i>
        </div>
        <h2 style="font-family: var(--font-heading); font-size: 1.25rem; color: var(--color-text);">Delivery</h2>
      </div>
      <div style="display: flex; flex-direction: column; gap: 12px;">
        <div style="background: var(--color-card-bg); padding: 20px 24px; border-radius: var(--radius-md); border: 1px solid var(--color-border);">
          <div style="display: flex; justify-content: space-between; align-items: center;">
            <div>
              <strong style="font-size: 14px; color: var(--color-text);">Standard Delivery</strong>
              <p style="font-size: 13px; color: var(--color-text-muted); margin: 4px 0 0;">2-4 business days</p>
            </div>
            <span style="font-size: 14px; font-weight: 600; color: var(--color-primary);">Free over £50</span>
          </div>
        </div>
        <div style="background: var(--color-card-bg); padding: 20px 24px; border-radius: var(--radius-md); border: 1px solid var(--color-border);">
          <div style="display: flex; justify-content: space-between; align-items: center;">
            <div>
              <strong style="font-size: 14px; color: var(--color-text);">Express Delivery</strong>
              <p style="font-size: 13px; color: var(--color-text-muted); margin: 4px 0 0;">Next business day</p>
            </div>
            <span style="font-size: 14px; font-weight: 600; color: var(--color-text);">£4.99</span>
          </div>
        </div>
        <p style="font-size: 13px; color: var(--color-text-muted); line-height: 1.6; margin-top: 8px;">Orders placed before 2pm on weekdays are dispatched the same day. We currently deliver to the UK only.</p>
      </div>
    </div>

    <!-- Returns -->
    <div style="margin-bottom: 48px;">
      <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 24px;">
        <div style="width: 40px; height: 40px; background: var(--color-mint-mist); border-radius: 50%; display: flex; align-items: center; justify-content: center; color: var(--color-primary);">
          <i data-lucide="rotate-ccw"></i>
        </div>
        <h2 style="font-family: var(--font-heading); font-size: 1.25rem; color: var(--color-text);">Returns</h2>
      </div>
      <div style="background: var(--color-card-bg); padding: 24px; border-radius: var(--radius-md); border: 1px solid var(--color-border);">
        <p style="font-size: 14px; color: var(--color-text-body); line-height: 1.7; margin-bottom: 12px;">We offer a <strong>30-day satisfaction guarantee</strong> on all products. If you're not happy with your supplements, contact us within 30 days of delivery for a full refund.</p>
        <ul style="font-size: 14px; color: var(--color-text-body); line-height: 1.8; padding-left: 20px; list-style: disc;">
          <li>Products must be in their original packaging</li>
          <li>Opened products are eligible if less than half consumed</li>
          <li>Refunds processed within 5-7 business days</li>
        </ul>
      </div>
    </div>

    <!-- Guarantee -->
    <div>
      <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 24px;">
        <div style="width: 40px; height: 40px; background: var(--color-mint-mist); border-radius: 50%; display: flex; align-items: center; justify-content: center; color: var(--color-primary);">
          <i data-lucide="shield-check"></i>
        </div>
        <h2 style="font-family: var(--font-heading); font-size: 1.25rem; color: var(--color-text);">Our Guarantee</h2>
      </div>
      <div style="background: var(--color-mint-mist); padding: 28px; border-radius: var(--radius-md); text-align: center;">
        <p style="font-size: 15px; color: var(--color-text); font-weight: 500; line-height: 1.6;">We stand behind every supplement we sell. If it doesn't work for you, we'll make it right — no questions asked.</p>
        <a href="/pages/contact" class="btn btn--outline btn--sm" style="margin-top: 16px;">Contact Support</a>
      </div>
    </div>
  </div>
</section>
