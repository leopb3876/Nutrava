<section class="sn-acct">
  <div class="sn-acct__inner">

    <!-- Header -->
    <div class="sn-acct-profile">
      <div>
        <a href="/account" class="sn-acct-back">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
          Back to account
        </a>
        <h1>Your <em>addresses</em>.</h1>
      </div>
      <button class="sn-btn-mini sn-btn-mini--ink" id="add-address-toggle" type="button">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        Add address
      </button>
    </div>

    <!-- Add new address form -->
    <div id="add-address-form" class="sn-acct-card sn-acct-card--cream" style="display: none; margin-bottom: 28px;">
      <div class="sn-acct-section__head" style="margin-bottom: 18px;">
        <div class="sn-acct-section__icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
        </div>
        <h2 class="sn-acct-section__title">New address</h2>
      </div>

      {% form 'customer_address', customer.new_address %}
        <div class="sn-auth-form">
          <div class="sn-form-grid">
            <div class="sn-form-field">
              <label for="address-first-name-new">First name</label>
              <input type="text" id="address-first-name-new" name="address[first_name]" autocomplete="given-name">
            </div>
            <div class="sn-form-field">
              <label for="address-last-name-new">Last name</label>
              <input type="text" id="address-last-name-new" name="address[last_name]" autocomplete="family-name">
            </div>
          </div>
          <div class="sn-form-field">
            <label for="address-company-new">Company (optional)</label>
            <input type="text" id="address-company-new" name="address[company]" autocomplete="organization">
          </div>
          <div class="sn-form-field">
            <label for="address-address1-new">Address</label>
            <input type="text" id="address-address1-new" name="address[address1]" autocomplete="address-line1" required>
          </div>
          <div class="sn-form-field">
            <label for="address-address2-new">Apartment, suite, etc. (optional)</label>
            <input type="text" id="address-address2-new" name="address[address2]" autocomplete="address-line2">
          </div>
          <div class="sn-form-grid">
            <div class="sn-form-field">
              <label for="address-city-new">City</label>
              <input type="text" id="address-city-new" name="address[city]" autocomplete="address-level2" required>
            </div>
            <div class="sn-form-field">
              <label for="address-country-new">Country</label>
              <select id="address-country-new" name="address[country]" data-default="{{ form.country }}" autocomplete="country">{{ all_country_option_tags }}</select>
            </div>
          </div>
          <div class="sn-form-grid">
            <div class="sn-form-field">
              <label for="address-province-new">State / Province</label>
              <select id="address-province-new" name="address[province]" data-default="{{ form.province }}" autocomplete="address-level1"></select>
            </div>
            <div class="sn-form-field">
              <label for="address-zip-new">Postal / ZIP code</label>
              <input type="text" id="address-zip-new" name="address[zip]" autocomplete="postal-code" required>
            </div>
          </div>
          <div class="sn-form-field">
            <label for="address-phone-new">Phone (optional)</label>
            <input type="tel" id="address-phone-new" name="address[phone]" autocomplete="tel">
          </div>
          <div class="sn-form-checkbox">
            {{ form.set_as_default_checkbox }}
            <label for="address_default_address_new" style="margin: 0; cursor: pointer;">Set as default address</label>
          </div>
          <div style="display: flex; gap: 10px; flex-wrap: wrap; margin-top: 6px;">
            <button type="submit" class="sn-btn-mini sn-btn-mini--ink">Save address</button>
            <button type="button" class="sn-btn-mini" onclick="document.getElementById('add-address-form').style.display='none';">Cancel</button>
          </div>
        </div>
      {% endform %}
    </div>

    <!-- Existing addresses -->
    <div class="sn-acct-section">
      {%- if customer.addresses.size > 0 -%}
        {%- for address in customer.addresses -%}
          <div class="sn-acct-card">
            <!-- View mode -->
            <div id="address-view-{{ address.id }}">
              <div class="sn-acct-order-row">
                <div>
                  {%- if address == customer.default_address -%}
                    <span class="sn-badge sn-badge--delivered" style="margin-bottom: 10px;">Default</span>
                  {%- endif -%}
                  <div class="sn-acct-settings__value">{{ address | format_address }}</div>
                </div>
                <div class="sn-acct-card__actions" style="margin-top: 0;">
                  <button class="sn-btn-mini" type="button" onclick="toggleEditAddress('{{ address.id }}')">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                    Edit
                  </button>
                  {% form 'customer_address', address %}
                    <input type="hidden" name="_method" value="delete">
                    <button type="submit" class="sn-btn-mini sn-btn-mini--danger" onclick="return confirm('Delete this address?');">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/></svg>
                      Delete
                    </button>
                  {% endform %}
                </div>
              </div>
            </div>

            <!-- Edit mode -->
            <div id="address-edit-{{ address.id }}" style="display: none;">
              <div class="sn-acct-section__head" style="margin-bottom: 18px;">
                <div class="sn-acct-section__icon">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                </div>
                <h3 class="sn-acct-section__title">Edit address</h3>
              </div>

              {% form 'customer_address', address %}
                <div class="sn-auth-form">
                  <div class="sn-form-grid">
                    <div class="sn-form-field">
                      <label for="address-first-name-{{ address.id }}">First name</label>
                      <input type="text" id="address-first-name-{{ address.id }}" name="address[first_name]" value="{{ address.first_name }}" autocomplete="given-name">
                    </div>
                    <div class="sn-form-field">
                      <label for="address-last-name-{{ address.id }}">Last name</label>
                      <input type="text" id="address-last-name-{{ address.id }}" name="address[last_name]" value="{{ address.last_name }}" autocomplete="family-name">
                    </div>
                  </div>
                  <div class="sn-form-field">
                    <label for="address-company-{{ address.id }}">Company (optional)</label>
                    <input type="text" id="address-company-{{ address.id }}" name="address[company]" value="{{ address.company }}" autocomplete="organization">
                  </div>
                  <div class="sn-form-field">
                    <label for="address-address1-{{ address.id }}">Address</label>
                    <input type="text" id="address-address1-{{ address.id }}" name="address[address1]" value="{{ address.address1 }}" autocomplete="address-line1" required>
                  </div>
                  <div class="sn-form-field">
                    <label for="address-address2-{{ address.id }}">Apartment, suite, etc. (optional)</label>
                    <input type="text" id="address-address2-{{ address.id }}" name="address[address2]" value="{{ address.address2 }}" autocomplete="address-line2">
                  </div>
                  <div class="sn-form-grid">
                    <div class="sn-form-field">
                      <label for="address-city-{{ address.id }}">City</label>
                      <input type="text" id="address-city-{{ address.id }}" name="address[city]" value="{{ address.city }}" autocomplete="address-level2" required>
                    </div>
                    <div class="sn-form-field">
                      <label for="address-country-{{ address.id }}">Country</label>
                      <select id="address-country-{{ address.id }}" name="address[country]" data-default="{{ address.country }}" autocomplete="country">{{ all_country_option_tags }}</select>
                    </div>
                  </div>
                  <div class="sn-form-grid">
                    <div class="sn-form-field">
                      <label for="address-province-{{ address.id }}">State / Province</label>
                      <select id="address-province-{{ address.id }}" name="address[province]" data-default="{{ address.province }}" autocomplete="address-level1"></select>
                    </div>
                    <div class="sn-form-field">
                      <label for="address-zip-{{ address.id }}">Postal / ZIP code</label>
                      <input type="text" id="address-zip-{{ address.id }}" name="address[zip]" value="{{ address.zip }}" autocomplete="postal-code" required>
                    </div>
                  </div>
                  <div class="sn-form-field">
                    <label for="address-phone-{{ address.id }}">Phone (optional)</label>
                    <input type="tel" id="address-phone-{{ address.id }}" name="address[phone]" value="{{ address.phone }}" autocomplete="tel">
                  </div>
                  <div class="sn-form-checkbox">
                    {{ form.set_as_default_checkbox }}
                    <label for="address_default_address_{{ address.id }}" style="margin: 0; cursor: pointer;">Set as default address</label>
                  </div>
                  <div style="display: flex; gap: 10px; flex-wrap: wrap; margin-top: 6px;">
                    <button type="submit" class="sn-btn-mini sn-btn-mini--ink">Save changes</button>
                    <button type="button" class="sn-btn-mini" onclick="toggleEditAddress('{{ address.id }}')">Cancel</button>
                  </div>
                </div>
              {% endform %}
            </div>
          </div>
        {%- endfor -%}
      {%- else -%}
        <div class="sn-acct-card sn-acct-card--cream sn-acct-card--center">
          <div style="width:48px; height:48px; background: var(--sn-paper); border-radius: 50%; display: grid; place-items: center; margin: 0 auto 16px; color: var(--sn-amber);">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" width="22" height="22"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          </div>
          <p style="color: var(--sn-ink-soft); margin: 0 0 18px;">No addresses saved yet.</p>
          <button class="sn-btn sn-btn--ink" type="button" onclick="document.getElementById('add-address-form').style.display='block'; window.scrollTo({top: 0, behavior: 'smooth'});">
            Add your first address
          </button>
        </div>
      {%- endif -%}
    </div>

  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    var addToggle = document.getElementById('add-address-toggle');
    var addForm = document.getElementById('add-address-form');

    if (addToggle && addForm) {
      addToggle.addEventListener('click', function () {
        var isVisible = addForm.style.display !== 'none';
        addForm.style.display = isVisible ? 'none' : 'block';
        if (!isVisible) addForm.scrollIntoView({ behavior: 'smooth', block: 'start' });
      });
    }

    if (typeof Shopify !== 'undefined' && Shopify.CountryProvinceSelector) {
      new Shopify.CountryProvinceSelector('address-country-new', 'address-province-new', {
        hideElement: 'address-province-new-wrap'
      });

      {% for address in customer.addresses %}
        new Shopify.CountryProvinceSelector(
          'address-country-{{ address.id }}',
          'address-province-{{ address.id }}',
          { hideElement: 'address-province-{{ address.id }}-wrap' }
        );
      {% endfor %}
    }
  });

  function toggleEditAddress(id) {
    var viewEl = document.getElementById('address-view-' + id);
    var editEl = document.getElementById('address-edit-' + id);
    if (viewEl && editEl) {
      var isEditing = editEl.style.display !== 'none';
      viewEl.style.display = isEditing ? 'block' : 'none';
      editEl.style.display = isEditing ? 'none' : 'block';
    }
  }
</script>

{{ 'shopify_common.js' | shopify_asset_url | script_tag }}
{{ 'customer_area.js' | shopify_asset_url | script_tag }}
