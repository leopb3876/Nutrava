<section class="sn-auth-shell">
  <div class="sn-auth-card">
    <div class="sn-auth-card__icon">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
    </div>
    <h1 class="sn-auth-card__title">Welcome <em>back</em>.</h1>
    <p class="sn-auth-card__sub">Sign in to your Nutrava account.</p>

    {%- if form.errors -%}
      <div class="sn-auth-msg sn-auth-msg--error">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        {{ form.errors | default_errors }}
      </div>
    {%- endif -%}

    <div id="login-form">
      {% form 'customer_login' %}
        <div class="sn-auth-form">
          <div class="sn-form-field">
            <label for="customer-email">Email</label>
            <input type="email" id="customer-email" name="customer[email]" autocomplete="email" autocapitalize="off" placeholder="you@example.com" required>
          </div>
          <div class="sn-form-field">
            <label for="customer-password">Password</label>
            <input type="password" id="customer-password" name="customer[password]" autocomplete="current-password" placeholder="••••••••" required>
          </div>
          <div class="sn-auth-form__forgot">
            <a href="#" id="forgot-password-link">Forgot password?</a>
          </div>
          <button type="submit" class="sn-auth-form__submit">Sign in</button>
        </div>
      {% endform %}

      <p class="sn-auth-form__switch">Don't have an account? <a href="/account/register">Create one</a></p>
    </div>

    <div id="recover-form" style="display: none;">
      {% form 'recover_customer_password' %}
        {%- if form.posted_successfully? -%}
          <div class="sn-auth-msg sn-auth-msg--success">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            We've emailed you a link to reset your password.
          </div>
        {%- endif -%}

        <p class="sn-auth-card__sub">We'll send you a link to reset your password.</p>
        <div class="sn-auth-form">
          <div class="sn-form-field">
            <label for="recover-email">Email</label>
            <input type="email" id="recover-email" name="email" autocomplete="email" autocapitalize="off" placeholder="you@example.com" required>
          </div>
          <button type="submit" class="sn-auth-form__submit">Send reset link</button>
        </div>
      {% endform %}

      <p class="sn-auth-form__switch"><a href="#" id="back-to-login-link">← Back to sign in</a></p>
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    var loginForm = document.getElementById('login-form');
    var recoverForm = document.getElementById('recover-form');
    var forgotLink = document.getElementById('forgot-password-link');
    var backLink = document.getElementById('back-to-login-link');

    if (forgotLink) forgotLink.addEventListener('click', function (e) {
      e.preventDefault();
      loginForm.style.display = 'none';
      recoverForm.style.display = 'block';
    });
    if (backLink) backLink.addEventListener('click', function (e) {
      e.preventDefault();
      recoverForm.style.display = 'none';
      loginForm.style.display = 'block';
    });
    if (window.location.hash === '#recover') {
      loginForm.style.display = 'none';
      recoverForm.style.display = 'block';
    }
  });
</script>
