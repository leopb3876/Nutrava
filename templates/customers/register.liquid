<section class="sn-auth-shell">
  <div class="sn-auth-card">
    <div class="sn-auth-card__icon">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="8.5" cy="7" r="4"/><line x1="20" y1="8" x2="20" y2="14"/><line x1="23" y1="11" x2="17" y2="11"/></svg>
    </div>
    <h1 class="sn-auth-card__title">Create an <em>account</em>.</h1>
    <p class="sn-auth-card__sub">Track your orders, save your routine, and skip the form at checkout next time.</p>

    {%- if form.errors -%}
      <div class="sn-auth-msg sn-auth-msg--error">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        {{ form.errors | default_errors }}
      </div>
    {%- endif -%}

    {% form 'create_customer' %}
      <div class="sn-auth-form">
        <div class="sn-form-grid">
          <div class="sn-form-field">
            <label for="customer-first-name">First name</label>
            <input type="text" id="customer-first-name" name="customer[first_name]" autocomplete="given-name" required>
          </div>
          <div class="sn-form-field">
            <label for="customer-last-name">Last name</label>
            <input type="text" id="customer-last-name" name="customer[last_name]" autocomplete="family-name" required>
          </div>
        </div>
        <div class="sn-form-field">
          <label for="customer-email">Email</label>
          <input type="email" id="customer-email" name="customer[email]" autocomplete="email" autocapitalize="off" placeholder="you@example.com" required>
        </div>
        <div class="sn-form-field">
          <label for="customer-password">Password</label>
          <input type="password" id="customer-password" name="customer[password]" autocomplete="new-password" placeholder="At least 8 characters" required>
        </div>
        <button type="submit" class="sn-auth-form__submit">Create account</button>
      </div>
    {% endform %}

    <p class="sn-auth-form__switch">Already have an account? <a href="/account/login">Sign in</a></p>
  </div>
</section>
