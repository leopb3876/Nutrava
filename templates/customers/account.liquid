<section class="sn-acct">
  <div class="sn-acct__inner">

    <!-- Profile -->
    <div class="sn-acct-profile">
      <div>
        <h1>Welcome back, <em>{{ customer.first_name | default: 'friend' }}</em>.</h1>
        <p class="sn-acct-profile__email">{{ customer.email }}</p>
      </div>
      <a href="/account/logout" class="sn-btn-mini">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
        Sign out
      </a>
    </div>

    <!-- Stats -->
    <div class="sn-acct-stats">
      <div class="sn-acct-stat">
        <div class="sn-acct-stat__icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M16.5 9.4l-9-5.19M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>
        </div>
        <span class="sn-acct-stat__num">{{ customer.orders_count }}</span>
        <span class="sn-acct-stat__label">Orders</span>
      </div>
      <div class="sn-acct-stat">
        <div class="sn-acct-stat__icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/></svg>
        </div>
        <span class="sn-acct-stat__num">0</span>
        <span class="sn-acct-stat__label">Subscriptions</span>
      </div>
      <div class="sn-acct-stat">
        <div class="sn-acct-stat__icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
        </div>
        <span class="sn-acct-stat__num" data-in-transit-count>0</span>
        <span class="sn-acct-stat__label">In transit</span>
      </div>
    </div>

    <!-- Order history -->
    <div class="sn-acct-section">
      <div class="sn-acct-section__head">
        <div class="sn-acct-section__icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        </div>
        <h2 class="sn-acct-section__title">Order history</h2>
      </div>

      {%- if customer.orders.size > 0 -%}
        {%- for order in customer.orders -%}
          <div class="sn-acct-card">
            <div class="sn-acct-order-row">
              <div>
                <h3 class="sn-acct-order-row__title">{{ order.name }}</h3>
                <p class="sn-acct-order-row__meta">{{ order.created_at | date: "%b %d, %Y" }} · {{ order.line_items.size }} item{{ order.line_items.size | pluralize: '', 's' }}</p>
                {%- if order.fulfillment_status == 'fulfilled' -%}
                  <span class="sn-badge sn-badge--delivered">Delivered</span>
                {%- elsif order.fulfillment_status == 'partial' -%}
                  <span class="sn-badge sn-badge--transit">Partially shipped</span>
                {%- else -%}
                  <span class="sn-badge sn-badge--transit">Processing</span>
                {%- endif -%}
              </div>
              <div>
                <span class="sn-acct-order-row__price">{{ order.total_price | money }}</span>
              </div>
            </div>
            <div class="sn-acct-card__actions">
              <a href="{{ order.customer_url }}" class="sn-btn-mini">View details</a>
            </div>
          </div>
        {%- endfor -%}
      {%- else -%}
        <div class="sn-acct-card sn-acct-card--cream sn-acct-card--center">
          <p style="color: var(--sn-ink-soft); margin: 0 0 18px;">No orders yet — let's find what works for your skin.</p>
          <a href="/pages/quiz" class="sn-btn sn-btn--ink">Take the Quiz</a>
        </div>
      {%- endif -%}
    </div>

    <!-- Settings -->
    <div class="sn-acct-section">
      <div class="sn-acct-section__head">
        <div class="sn-acct-section__icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
        </div>
        <h2 class="sn-acct-section__title">Account settings</h2>
      </div>
      <div class="sn-acct-card">
        <div class="sn-acct-settings__row">
          <div>
            <div class="sn-acct-settings__label">Full name</div>
            <div class="sn-acct-settings__value">{{ customer.first_name }} {{ customer.last_name }}</div>
          </div>
        </div>
        <div class="sn-acct-settings__row">
          <div>
            <div class="sn-acct-settings__label">Email</div>
            <div class="sn-acct-settings__value">{{ customer.email }}</div>
          </div>
        </div>
        <div class="sn-acct-settings__row">
          <div style="min-width: 0;">
            <div class="sn-acct-settings__label">Default address</div>
            <div class="sn-acct-settings__value">
              {%- if customer.default_address -%}
                {{ customer.default_address | format_address }}
              {%- else -%}
                No address saved
              {%- endif -%}
            </div>
          </div>
          <a href="/account/addresses" class="sn-acct-settings__action">Manage</a>
        </div>
      </div>
    </div>

  </div>
</section>
