<section class="sn-auth-shell">
  <div class="sn-auth-card">
    <div class="sn-auth-card__icon">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4"/></svg>
    </div>
    <h1 class="sn-auth-card__title">Reset your <em>password</em>.</h1>
    <p class="sn-auth-card__sub">Enter your email and we'll send you a link to set a new one.</p>

    {%- if form.errors -%}
      <div class="sn-auth-msg sn-auth-msg--error">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        {{ form.errors | default_errors }}
      </div>
    {%- endif -%}

    {% form 'recover_customer_password' %}
      {%- if form.posted_successfully? -%}
        <div class="sn-auth-msg sn-auth-msg--success">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          Check your inbox — we've sent you a password reset link.
        </div>
      {%- else -%}
        <div class="sn-auth-form">
          <div class="sn-form-field">
            <label for="RecoverEmail">Email</label>
            <input type="email" id="RecoverEmail" name="email" autocomplete="email" autocapitalize="off" placeholder="you@example.com" required>
          </div>
          <button type="submit" class="sn-auth-form__submit">Send reset link</button>
        </div>
      {%- endif -%}
    {% endform %}

    <p class="sn-auth-form__switch"><a href="{{ routes.account_login_url }}">← Back to sign in</a></p>
  </div>
</section>
