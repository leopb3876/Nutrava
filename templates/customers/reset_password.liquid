<section class="account-hero section-padding">
  <div class="container container--narrow">
    <div class="auth-page">
      <div class="auth-page__icon">
        <i data-lucide="key" style="width:24px; height:24px;"></i>
      </div>
      <h1 class="auth-page__title">Reset Your Password</h1>
      <p class="auth-page__subtitle">Enter your email and we'll send you a link to reset your password</p>

      {% form 'recover_customer_password' %}
        {%- if form.errors -%}
          <div class="auth-page__errors">{{ form.errors | default_errors }}</div>
        {%- endif -%}

        {%- if form.posted_successfully? -%}
          <div class="auth-page__success">
            <p>We've sent you a password reset email. Please check your inbox and follow the instructions.</p>
          </div>
        {%- else -%}
          <div class="auth-field">
            <label for="RecoverEmail">Email</label>
            <input
              type="email"
              id="RecoverEmail"
              name="email"
              autocomplete="email"
              autocapitalize="off"
              placeholder="you@example.com"
              required
            >
          </div>

          <button type="submit" class="btn btn--primary">Reset Password</button>
        {%- endif -%}
      {% endform %}

      <p style="text-align:center; margin-top:1.5rem;">
        <a href="{{ routes.account_login_url }}" class="auth-page__forgot">Back to Login</a>
      </p>
    </div>
  </div>
</section>
