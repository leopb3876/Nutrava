<section class="sn-acct">
  <div class="sn-acct__inner">

    <!-- Header -->
    <div class="sn-acct-profile">
      <div>
        <a href="/account" class="sn-acct-back">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
          Back to account
        </a>
        <h1>{{ order.name }}</h1>
        <p class="sn-acct-profile__email">Placed on {{ order.created_at | date: "%B %d, %Y at %I:%M %p" }}</p>
      </div>
    </div>

    <!-- Status -->
    <div class="sn-acct-card sn-acct-card--cream" style="margin-bottom: 28px;">
      <div style="display: flex; gap: 32px; flex-wrap: wrap;">
        <div>
          <div class="sn-acct-settings__label">Payment</div>
          <span class="sn-badge sn-badge--{{ order.financial_status }}">{{ order.financial_status_label }}</span>
        </div>
        <div>
          <div class="sn-acct-settings__label">Fulfillment</div>
          {%- if order.fulfillment_status == 'fulfilled' -%}
            <span class="sn-badge sn-badge--delivered">Delivered</span>
          {%- elsif order.fulfillment_status == 'partial' -%}
            <span class="sn-badge sn-badge--transit">Partially shipped</span>
          {%- elsif order.fulfillment_status == nil -%}
            <span class="sn-badge sn-badge--transit">Processing</span>
          {%- else -%}
            <span class="sn-badge sn-badge--transit">{{ order.fulfillment_status_label }}</span>
          {%- endif -%}
        </div>
      </div>
    </div>

    <!-- Items -->
    <div class="sn-acct-section">
      <div class="sn-acct-section__head">
        <div class="sn-acct-section__icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M16.5 9.4l-9-5.19M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>
        </div>
        <h2 class="sn-acct-section__title">Items</h2>
      </div>
      <div class="sn-acct-card">
        <div class="sn-order-items">
          {%- for line_item in order.line_items -%}
            <div class="sn-order-item">
              <div class="sn-order-item__image">
                {%- if line_item.image -%}
                  <img src="{{ line_item.image | image_url: width: 200 }}" alt="{{ line_item.title | escape }}" loading="lazy">
                {%- else -%}
                  <div class="sn-order-item__placeholder">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10z"/></svg>
                  </div>
                {%- endif -%}
              </div>
              <div>
                <h4 class="sn-order-item__title">{{ line_item.title }}</h4>
                {%- if line_item.variant.title != 'Default Title' -%}
                  <p class="sn-order-item__meta">{{ line_item.variant.title }}</p>
                {%- endif -%}
                {%- if line_item.sku != blank -%}
                  <p class="sn-order-item__meta">SKU: {{ line_item.sku }}</p>
                {%- endif -%}
              </div>
              <div class="sn-order-item__qty">× {{ line_item.quantity }}</div>
              <div class="sn-order-item__price">{{ line_item.final_line_price | money }}</div>
            </div>
          {%- endfor -%}
        </div>
      </div>
    </div>

    <!-- Totals -->
    <div class="sn-acct-section">
      <div class="sn-acct-card">
        <div class="sn-order-totals">
          <div class="sn-order-totals__row">
            <span>Subtotal</span>
            <span>{{ order.line_items_subtotal_price | money }}</span>
          </div>
          {%- for shipping_method in order.shipping_methods -%}
            <div class="sn-order-totals__row">
              <span>Shipping ({{ shipping_method.title }})</span>
              <span>{{ shipping_method.price | money }}</span>
            </div>
          {%- endfor -%}
          {%- for tax_line in order.tax_lines -%}
            <div class="sn-order-totals__row">
              <span>Tax ({{ tax_line.title }} {{ tax_line.rate | times: 100 }}%)</span>
              <span>{{ tax_line.price | money }}</span>
            </div>
          {%- endfor -%}
          {%- if order.total_discounts > 0 -%}
            <div class="sn-order-totals__row sn-order-totals__row--discount">
              <span>Discount</span>
              <span>− {{ order.total_discounts | money }}</span>
            </div>
          {%- endif -%}
          <div class="sn-order-totals__row sn-order-totals__row--total">
            <span>Total</span>
            <span>{{ order.total_price | money }}</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Shipping address -->
    {%- if order.shipping_address -%}
      <div class="sn-acct-section">
        <div class="sn-acct-section__head">
          <div class="sn-acct-section__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          </div>
          <h2 class="sn-acct-section__title">Shipping address</h2>
        </div>
        <div class="sn-acct-card">
          <div class="sn-acct-settings__value">{{ order.shipping_address | format_address }}</div>
        </div>
      </div>
    {%- endif -%}

    <!-- Billing address -->
    {%- if order.billing_address -%}
      <div class="sn-acct-section">
        <div class="sn-acct-section__head">
          <div class="sn-acct-section__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>
          </div>
          <h2 class="sn-acct-section__title">Billing address</h2>
        </div>
        <div class="sn-acct-card">
          <div class="sn-acct-settings__value">{{ order.billing_address | format_address }}</div>
        </div>
      </div>
    {%- endif -%}

  </div>
</section>
