<div class="blog-page">
  <section class="section-padding">
    <div class="container">

      <div class="blog-page__header">
        <h1 class="blog-page__title">{{ blog.title }}</h1>
        {% if blog.tags.size > 0 %}
          <div class="blog-page__tags">
            <a href="{{ blog.url }}" class="blog-tag {% unless current_tags %}blog-tag--active{% endunless %}">All</a>
            {% for tag in blog.all_tags %}
              <a href="{{ blog.url }}/tagged/{{ tag | handleize }}" class="blog-tag {% if current_tags contains tag %}blog-tag--active{% endif %}">{{ tag }}</a>
            {% endfor %}
          </div>
        {% endif %}
      </div>

      {% paginate blog.articles by 12 %}
        {% if blog.articles.size > 0 %}
          <div class="blog-grid">
            {% for article in blog.articles %}
              <a href="{{ article.url }}" class="blog-card">
                {% if article.image %}
                  <img src="{{ article.image | image_url: width: 400 }}" alt="{{ article.image.alt | default: article.title | escape }}" class="blog-card__image" width="400" loading="lazy">
                {% else %}
                  <div class="blog-card__placeholder">
                    <i data-lucide="file-text"></i>
                  </div>
                {% endif %}
                <div class="blog-card__body">
                  <span class="blog-card__date">{{ article.published_at | date: '%B %d, %Y' }}</span>
                  <h2 class="blog-card__title">{{ article.title }}</h2>
                  <p class="blog-card__excerpt">{{ article.excerpt_or_content | strip_html | truncate: 150 }}</p>
                  <div class="blog-card__meta">
                    <span class="blog-card__author">
                      <i data-lucide="user"></i>
                      {{ article.author }}
                    </span>
                  </div>
                </div>
              </a>
            {% endfor %}
          </div>

          {% if paginate.pages > 1 %}
            <nav class="pagination" aria-label="Blog pagination">
              {% if paginate.previous %}
                <a href="{{ paginate.previous.url }}" class="pagination__link pagination__prev">
                  <i data-lucide="chevron-left"></i> Previous
                </a>
              {% endif %}

              {% for part in paginate.parts %}
                {% if part.is_link %}
                  <a href="{{ part.url }}" class="pagination__link">{{ part.title }}</a>
                {% else %}
                  {% if part.title == paginate.current_page %}
                    <span class="pagination__link pagination__current">{{ part.title }}</span>
                  {% else %}
                    <span class="pagination__link pagination__gap">{{ part.title }}</span>
                  {% endif %}
                {% endif %}
              {% endfor %}

              {% if paginate.next %}
                <a href="{{ paginate.next.url }}" class="pagination__link pagination__next">
                  Next <i data-lucide="chevron-right"></i>
                </a>
              {% endif %}
            </nav>
          {% endif %}
        {% else %}
          <div class="blog-empty">
            <div class="blog-empty__icon">
              <i data-lucide="file-text"></i>
            </div>
            <h2 class="blog-empty__title">No articles yet</h2>
            <p class="blog-empty__text">Check back soon for the latest on skincare, ingredients, and routines.</p>
          </div>
        {% endif %}
      {% endpaginate %}

    </div>
  </section>
</div>

<style>
  .blog-page__header {
    margin-bottom: 40px;
  }
  .blog-page__title {
    font-family: var(--font-heading);
    font-size: 2.25rem;
    color: var(--color-text);
    margin-bottom: 16px;
  }

  /* Tags */
  .blog-page__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .blog-tag {
    display: inline-block;
    padding: 6px 16px;
    font-size: 13px;
    font-weight: 600;
    color: var(--color-text-body);
    text-decoration: none;
    border: 1.5px solid var(--color-border);
    border-radius: 20px;
    transition: all 0.2s;
  }
  .blog-tag:hover,
  .blog-tag--active {
    background: var(--color-primary);
    color: #fff;
    border-color: var(--color-primary);
  }

  /* Blog Grid */
  .blog-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 28px;
    margin-bottom: 40px;
  }

  /* Blog Card */
  .blog-card {
    background: #fff;
    border: 1.5px solid var(--color-border);
    border-radius: 16px;
    overflow: hidden;
    text-decoration: none;
    transition: all 0.25s;
    display: flex;
    flex-direction: column;
  }
  .blog-card:hover {
    border-color: var(--color-primary);
    transform: translateY(-4px);
    box-shadow: var(--shadow-hover);
  }
  .blog-card__image {
    width: 100%;
    height: 200px;
    object-fit: cover;
    display: block;
  }
  .blog-card__placeholder {
    width: 100%;
    height: 200px;
    background: var(--color-card-bg, #f5f0eb);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .blog-card__placeholder i { width: 40px; height: 40px; color: var(--color-primary); }
  .blog-card__body {
    padding: 20px;
    flex: 1;
    display: flex;
    flex-direction: column;
  }
  .blog-card__date {
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    color: var(--color-primary);
    margin-bottom: 8px;
  }
  .blog-card__title {
    font-family: var(--font-heading);
    font-size: 1.15rem;
    color: var(--color-text);
    margin-bottom: 8px;
    line-height: 1.3;
  }
  .blog-card__excerpt {
    font-size: 13px;
    color: var(--color-text-muted);
    line-height: 1.5;
    flex: 1;
    margin-bottom: 12px;
  }
  .blog-card__meta {
    display: flex;
    align-items: center;
    gap: 12px;
    border-top: 1px solid var(--color-border);
    padding-top: 12px;
  }
  .blog-card__author {
    display: flex;
    align-items: center;
    gap: 4px;
    font-size: 13px;
    color: var(--color-text-muted);
  }
  .blog-card__author i { width: 14px; height: 14px; }

  /* Blog Empty */
  .blog-empty {
    text-align: center;
    padding: 64px 0;
  }
  .blog-empty__icon {
    width: 80px;
    height: 80px;
    margin: 0 auto 24px;
    background: var(--color-card-bg, #f5f0eb);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .blog-empty__icon i { width: 36px; height: 36px; color: var(--color-primary); }
  .blog-empty__title {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    color: var(--color-text);
    margin-bottom: 8px;
  }
  .blog-empty__text {
    color: var(--color-text-muted);
  }

  /* Pagination (shared with search) */
  .pagination {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 8px;
    padding: 24px 0;
  }
  .pagination__link {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 8px 14px;
    font-size: 14px;
    color: var(--color-text);
    text-decoration: none;
    border: 1.5px solid var(--color-border);
    border-radius: 8px;
    transition: all 0.2s;
  }
  .pagination__link:hover { border-color: var(--color-primary); color: var(--color-primary); }
  .pagination__current {
    background: var(--color-primary);
    color: #fff;
    border-color: var(--color-primary);
  }
  .pagination__gap { border-color: transparent; }
  .pagination__link i { width: 16px; height: 16px; }
</style>
