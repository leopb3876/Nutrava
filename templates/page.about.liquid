<!-- OUR PROMISE -->
<section class="sn-page-section sn-page-section--narrow">
  <h2 class="sn-page-section__title">Our <em>promise</em>.</h2>
  <div class="sn-promises">
    <div class="sn-promise">
      <div class="sn-promise__check"></div>
      <div>
        <h4 class="sn-promise__title">Clean formulas</h4>
        <p class="sn-promise__text">No synthetic fragrance, no sulphates, no mystery proprietary blends. Just the ingredients that earn a spot on the label.</p>
      </div>
    </div>
    <div class="sn-promise">
      <div class="sn-promise__check"></div>
      <div>
        <h4 class="sn-promise__title">Clinically meaningful percentages</h4>
        <p class="sn-promise__text">Vitamin C at levels that brighten. Retinol-alternative at levels that work. Hyaluronic acid in multiple weights, not a decorative drop. No pixie dust.</p>
      </div>
    </div>
    <div class="sn-promise">
      <div class="sn-promise__check"></div>
      <div>
        <h4 class="sn-promise__title">Transparent ingredients</h4>
