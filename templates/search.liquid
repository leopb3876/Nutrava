<section class="sn-page-hero">
  <span class="sn-page-hero__eyebrow">Search</span>
  <h1 class="sn-page-hero__title">Find your <em>match</em>.</h1>
  <p class="sn-page-hero__lead">Search by product name, ingredient, or skin concern.</p>
</section>

<section class="sn-page-section">

  <form action="{{ routes.search_url }}" method="get" class="sn-search-form" role="search">
    <div class="sn-search-input-wrap">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      <input
        type="search"
        name="q"
        value="{{ search.terms | escape }}"
        placeholder="Niacinamide, retinol, dark spots…"
        class="sn-search-input"
        aria-label="Search"
        autocomplete="off"
      >
      <button type="submit" class="sn-search-submit">Search</button>
    </div>
  </form>

  {% if search.performed %}
    {% if search.results_count > 0 %}
      <p class="sn-search-count">
        {{ search.results_count }} result{{ search.results_count | pluralize: '', 's' }} for "<strong>{{ search.terms }}</strong>"
      </p>

      {% paginate search.results by 12 %}
        <div class="sn-search-grid">
          {% for item in search.results %}
            {% if item.object_type == 'product' %}
              {%- assign category_label = item.type | default: item.tags.first -%}
              <a href="{{ item.url }}" class="sn-product">
                <div class="sn-product__visual">
                  {%- if item.featured_image -%}
                    <img src="{{ item.featured_image | image_url: width: 600 }}" alt="{{ item.featured_image.alt | default: item.title | escape }}" loading="lazy" width="300" height="300">
                  {%- else -%}
                    <div class="sn-product__bottle" data-label="{{ item.title | escape }}"></div>
                  {%- endif -%}
                </div>
                {%- if category_label != blank -%}
                  <span class="sn-product__cat">{{ category_label }}</span>
                {%- endif -%}
                <h3 class="sn-product__title">{{ item.title }}</h3>
                {%- if item.description != blank -%}
                  <p class="sn-product__desc">{{ item.description | strip_html | truncate: 90 }}</p>
                {%- endif -%}
                <div class="sn-product__row">
                  <span class="sn-product__price">{{ item.price | money_without_trailing_zeros }}</span>
                  <span class="sn-product__add" aria-hidden="true">+</span>
                </div>
              </a>
            {% else %}
              <a href="{{ item.url }}" class="sn-search-card">
                <span class="sn-search-card__type">{{ item.object_type | capitalize }}</span>
                <h3 class="sn-search-card__title">{{ item.title }}</h3>
                {% if item.content != blank %}
                  <p class="sn-search-card__excerpt">{{ item.content | strip_html | truncate: 140 }}</p>
                {% endif %}
              </a>
            {% endif %}
          {% endfor %}
        </div>

        {% if paginate.pages > 1 %}
          <nav class="sn-pagination" aria-label="Search results pagination">
            {% if paginate.previous %}
              <a href="{{ paginate.previous.url }}" class="sn-pagination__link" aria-label="Previous page">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
              </a>
            {% endif %}

            {% for part in paginate.parts %}
              {% if part.is_link %}
                <a href="{{ part.url }}" class="sn-pagination__link">{{ part.title }}</a>
              {% else %}
                {% if part.title == paginate.current_page %}
                  <span class="sn-pagination__link sn-pagination__current">{{ part.title }}</span>
                {% else %}
                  <span class="sn-pagination__link sn-pagination__gap">{{ part.title }}</span>
                {% endif %}
              {% endif %}
            {% endfor %}

            {% if paginate.next %}
              <a href="{{ paginate.next.url }}" class="sn-pagination__link" aria-label="Next page">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
              </a>
            {% endif %}
          </nav>
        {% endif %}
      {% endpaginate %}

    {% else %}
      <div class="sn-empty-state">
        <div class="sn-empty-state__icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="13.5" y1="8.5" x2="8.5" y2="13.5"/><line x1="8.5" y1="8.5" x2="13.5" y2="13.5"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        </div>
        <h2 class="sn-empty-state__title">No results <em>found</em>.</h2>
        <p class="sn-empty-state__text">We couldn't find anything for "<strong>{{ search.terms }}</strong>". Try a different search, or take the quiz to find your routine.</p>
        <div class="sn-empty-state__actions">
          <a href="/pages/quiz" class="sn-btn sn-btn--ink">Take the Quiz</a>
          <a href="/collections/all" class="sn-btn sn-btn--ghost">Browse all products</a>
        </div>
      </div>
    {% endif %}
  {% endif %}

</section>
