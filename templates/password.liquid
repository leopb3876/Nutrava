{% layout none %}
<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ shop.name }} — Coming Soon</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;1,400&family=Josefin+Sans:wght@300;400;500&display=swap" rel="stylesheet">
  {{ 'base.css' | asset_url | stylesheet_tag }}
  <script src="{{ 'lucide.min.js' | asset_url }}" defer onload="lucide.createIcons()"></script>
  {{ content_for_header }}
  <style>
    body {
      background: var(--color-bg);
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }

    .password-page {
      flex: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: var(--space-xl);
    }

    .password-content {
      max-width: 480px;
      width: 100%;
      text-align: center;
    }

    .password-logo {
      font-family: 'Josefin Sans', sans-serif;
      font-size: 1.6rem;
      font-weight: 400;
      color: var(--color-text);
      letter-spacing: 0.27em;
      text-transform: uppercase;
      margin-bottom: var(--space-3xl);
      display: block;
      text-decoration: none;
    }

    .password-icon {
      width: 64px;
      height: 64px;
      background: var(--color-mint-mist);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto var(--space-xl);
      color: var(--color-primary);
    }

    .password-heading {
      font-family: var(--font-heading);
      font-size: clamp(2rem, 5vw, 2.75rem);
      color: var(--color-text);
      margin-bottom: var(--space-md);
      line-height: 1.2;
    }

    .password-subtext {
      font-size: 16px;
      color: var(--color-text-muted);
      margin-bottom: var(--space-2xl);
      line-height: 1.6;
    }

    .password-form {
      display: flex;
      gap: var(--space-sm);
      max-width: 400px;
      margin: 0 auto var(--space-xl);
    }

    .password-form input[type="password"] {
      flex: 1;
      padding: 12px 16px;
      border: 1.5px solid var(--color-border);
      border-radius: var(--radius-sm);
      font-size: 14px;
      font-family: var(--font-body);
      color: var(--color-text);
      background: var(--color-card-bg);
      transition: border-color var(--transition-fast);
    }

    .password-form input[type="password"]:focus {
      outline: none;
      border-color: var(--color-primary);
      box-shadow: 0 0 0 3px rgba(90, 122, 94, 0.1);
    }

    .password-form button {
      padding: 12px 24px;
      font-size: 14px;
      font-weight: 600;
      white-space: nowrap;
    }

    .password-errors {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: var(--space-sm);
      background: #fef2f2;
      color: #c0392b;
      font-size: 14px;
      padding: var(--space-sm) var(--space-md);
      border-radius: var(--radius-sm);
      margin-bottom: var(--space-lg);
      max-width: 400px;
      margin-left: auto;
      margin-right: auto;
    }

    .password-footer {
      padding: var(--space-xl);
      text-align: center;
      font-size: 13px;
      color: var(--color-text-muted);
      border-top: 1px solid var(--color-border);
    }

    .password-footer a {
      color: var(--color-primary);
      font-weight: 600;
    }

    .password-footer a:hover {
      text-decoration: underline;
    }

    @media (max-width: 480px) {
      .password-form {
        flex-direction: column;
      }
    }
  </style>
</head>
<body>

  <div class="password-page">
    <div class="password-content">
      <a href="/" class="password-logo">NUTRAVA</a>

      <div class="password-icon">
        <i data-lucide="lock" style="width:28px; height:28px;"></i>
      </div>

      <h1 class="password-heading">Coming Soon</h1>
      <p class="password-subtext">We're crafting something special for your wellness journey. Enter the store password to get early access.</p>

      {%- if form.errors -%}
        <div class="password-errors">
          <i data-lucide="alert-circle" style="width:16px; height:16px;"></i>
          {{ form.errors | default_errors }}
        </div>
      {%- endif -%}

      {% form 'storefront_password' %}
        <div class="password-form">
          <input type="password" name="password" placeholder="Enter store password" required>
          <button type="submit" class="btn btn--primary">Enter</button>
        </div>
      {% endform %}
    </div>
  </div>

  <footer class="password-footer">
    <p>&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.</p>
    <p style="margin-top: var(--space-xs);">
      Are you the store owner? <a href="/admin">Log in here</a>
    </p>
  </footer>

</body>
</html>
