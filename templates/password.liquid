{% layout none %}
<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ shop.name }} — Coming Soon</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght,SOFT,WONK@0,9..144,400..700,0..100,0..1;1,9..144,400..700,0..100,0..1&family=Inter+Tight:wght@400;500;600;700&display=swap" rel="stylesheet">
  {{ 'selfnamed.css' | asset_url | stylesheet_tag }}
  {{ content_for_header }}
  <style>
    body {
      background: var(--sn-paper);
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      font-family: var(--sn-ui);
      color: var(--sn-ink);
    }
    .sn-pw {
      flex: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 32px 24px 64px;
    }
    .sn-pw__inner {
      max-width: 480px;
      width: 100%;
      text-align: center;
      position: relative;
    }
    .sn-pw__logo {
      display: inline-flex;
      align-items: baseline;
      gap: 10px;
      font-family: var(--sn-display);
      font-size: 22px;
      font-weight: 600;
      letter-spacing: -0.03em;
      color: var(--sn-ink);
      text-decoration: none;
      margin-bottom: 56px;
    }
    .sn-pw__logo-mark { align-self: center; }
    .sn-pw__logo-text { line-height: 1; }
    .sn-pw__logo-jp {
      font-family: var(--sn-display);
      font-size: 16px;
      font-weight: 400;
      letter-spacing: 0.08em;
      color: var(--sn-amber);
      line-height: 1;
      border-left: 1px solid var(--sn-line);
      padding-left: 10px;
    }
    .sn-pw__logo-mark {
      width: 28px; height: 28px;
      border-radius: 8px;
      background: var(--sn-ink);
      color: var(--sn-paper);
      display: grid; place-items: center;
      font-size: 14px;
      font-weight: 700;
      font-family: var(--sn-ui);
    }
    .sn-pw__eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: var(--sn-cream);
      border-radius: var(--sn-r-pill);
      padding: 8px 18px;
      font-size: 12px;
      font-weight: 500;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      color: var(--sn-ink-soft);
      margin-bottom: 24px;
    }
    .sn-pw__eyebrow::before {
      content: "";
      width: 6px; height: 6px;
      border-radius: 50%;
      background: var(--sn-amber);
    }
    .sn-pw__title {
      font-family: var(--sn-display);
      font-weight: 500;
      font-size: clamp(40px, 6vw, 72px);
      letter-spacing: -0.04em;
      line-height: 1.0;
      margin: 0 auto 18px;
      max-width: 16ch;
    }
    .sn-pw__title em { font-style: italic; color: var(--sn-amber); font-weight: 400; }
    .sn-pw__sub {
      font-size: 17px;
      color: var(--sn-ink-soft);
      max-width: 480px;
      margin: 0 auto 36px;
      line-height: 1.55;
      letter-spacing: -0.01em;
    }
    .sn-pw__form-wrap {
      max-width: 420px;
      margin: 0 auto;
    }
    .sn-pw__form {
      display: flex;
      gap: 8px;
      background: var(--sn-cream);
      border: 1.5px solid transparent;
      border-radius: var(--sn-r-pill);
      padding: 6px 6px 6px 22px;
      transition: border-color .15s, background .15s;
    }
    .sn-pw__form:focus-within {
      background: var(--sn-paper);
      border-color: var(--sn-ink);
    }
    .sn-pw__form input[type="password"] {
      flex: 1;
      padding: 12px 0;
      border: none;
      outline: none;
      font-family: var(--sn-ui);
      font-size: 15px;
      color: var(--sn-ink);
      background: transparent;
    }
    .sn-pw__form input[type="password"]::placeholder { color: var(--sn-ink-mute); }
    .sn-pw__form button {
      background: var(--sn-ink);
      color: var(--sn-paper);
      border: none;
      border-radius: var(--sn-r-pill);
      padding: 12px 24px;
      font-family: var(--sn-ui);
      font-size: 12px;
      font-weight: 600;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      cursor: pointer;
      transition: background .2s;
      white-space: nowrap;
    }
    .sn-pw__form button:hover { background: #2a2a2a; }
    .sn-pw__error {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      background: var(--sn-peach);
      color: var(--sn-ink);
      font-size: 13.5px;
      padding: 10px 18px;
      border-radius: var(--sn-r-pill);
      margin: 0 auto 18px;
      max-width: 420px;
    }
    .sn-pw__footer {
      padding: 22px 24px;
      text-align: center;
      font-size: 13px;
      color: var(--sn-ink-mute);
      border-top: 1px solid var(--sn-line);
    }
    .sn-pw__footer p { margin: 0; }
    .sn-pw__footer p + p { margin-top: 4px; }
    .sn-pw__footer a {
      color: var(--sn-ink);
      text-decoration: underline;
      text-underline-offset: 3px;
    }
    .sn-pw__footer a:hover { color: var(--sn-amber); }

    @media (max-width: 480px) {
      .sn-pw__form {
        flex-direction: column;
        padding: 14px;
        border-radius: var(--sn-r-card);
      }
      .sn-pw__form input[type="password"] {
        padding: 10px 14px;
        background: var(--sn-paper);
        border-radius: var(--sn-r-pill);
      }
      .sn-pw__form button { width: 100%; }
    }
  </style>
</head>
<body>

  <div class="sn-pw">
    <div class="sn-pw__inner">
      <a href="/" class="sn-pw__logo">
        <span class="sn-pw__logo-mark">H</span>
        <span class="sn-pw__logo-text">{{ shop.name }}</span>
        <span class="sn-pw__logo-jp" aria-hidden="true">久恵</span>
      </a>

      <span class="sn-pw__eyebrow">Coming soon</span>
      <h1 class="sn-pw__title">Almost <em>here</em>.</h1>
      <p class="sn-pw__sub">We're putting the finishing touches on Hisae. Drop in the store password to take an early look.</p>

      {%- if form.errors -%}
        <div class="sn-pw__error">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="14" height="14"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
          {{ form.errors | default_errors }}
        </div>
      {%- endif -%}

      <div class="sn-pw__form-wrap">
        {% form 'storefront_password' %}
          <div class="sn-pw__form">
            <input type="password" name="password" placeholder="Enter store password" required>
            <button type="submit">Enter</button>
          </div>
        {% endform %}
      </div>
    </div>
  </div>

  <footer class="sn-pw__footer">
    <p>&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.</p>
    <p>Are you the store owner? <a href="/admin">Log in here</a></p>
  </footer>

</body>
</html>
